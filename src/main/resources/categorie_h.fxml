<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="categorie_hContainer" prefHeight="890.0" prefWidth="1125.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.categorieController">
    <children>
        <VBox layoutX="14.0" layoutY="55.0" prefHeight="247.0" prefWidth="314.0"
              spacing="10.0"
              AnchorPane.bottomAnchor="588.0" AnchorPane.leftAnchor="14.0" AnchorPane.topAnchor="55.0">
            <children>
                <TextField fx:id="tId" />
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Nom" />
                <TextField fx:id="tName" styleClass="text-field" />
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="description" />
                <TextField fx:id="tdescription" />
            </children>
        </VBox>

        <!-- ✅ Removed onTouchMoved="#tableview" -->
        <TableView fx:id="tableView" layoutX="341.0" layoutY="55.0"
                   prefHeight="399.0" prefWidth="809.0"
                   AnchorPane.leftAnchor="341.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="55.0">
            <columns>
                <TableColumn fx:id="ColID" prefWidth="45.0" text="ID" />
                <TableColumn fx:id="ColNom" prefWidth="86.0" text="Nom" />
                <TableColumn fx:id="Coldescription" prefWidth="109.0" text="description" />
            </columns>
        </TableView>

        <ButtonBar layoutX="-103.0" layoutY="457.0" prefHeight="84.0" prefWidth="387.0">
            <buttons>
                <!-- ✅ Fixed: matched to actual controller method names -->
                <Button fx:id="btnAjouter"   mnemonicParsing="false" onAction="#AjouterCategorie"  text="Ajouter" />
                <Button fx:id="btnModifier"  mnemonicParsing="false" onAction="#ModifierCategorie" text="Modifier" />
                <Button fx:id="btnSupprimer" mnemonicParsing="false" onAction="#SupprimerCategorie" text="Supprimer" />
            </buttons>
        </ButtonBar>

        <HBox layoutX="429.0" layoutY="470.0" prefHeight="238.0" prefWidth="627.0" />
    </children>
</AnchorPane>