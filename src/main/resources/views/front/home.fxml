<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controller.front.HomeController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="front-scroll">

    <VBox spacing="0">

        <!-- ══ BANNER AREA ══════════════════════════════════════ -->
        <VBox fx:id="bannerArea" minHeight="520" alignment="CENTER" spacing="0">

            <VBox styleClass="banner-content" alignment="CENTER" spacing="20">
                <Label text="LOIN DE LA VIE MONOTONE" styleClass="banner-sub"/>
                <Label text="Détendez Votre Esprit" styleClass="banner-title"/>
                <Label text="Découvrez la Tunisie de manière responsable et durable. Des expériences écologiques authentiques qui respectent l'environnement."
                       styleClass="banner-desc" wrapText="true"/>
                <Button text="COMMENCER" onAction="#handleCommencer" styleClass="btn-theme"/>
            </VBox>

            <HBox styleClass="booking-bar" alignment="CENTER_LEFT" spacing="20">
                <VBox alignment="CENTER_LEFT" spacing="4" minWidth="180">
                    <Label text="RÉSERVEZ" styleClass="booking-title"/>
                    <Label text="VOTRE CHAMBRE" styleClass="booking-title"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Date d'arrivée" styleClass="booking-label"/>
                    <DatePicker fx:id="checkInPicker" promptText="Arrivée" styleClass="booking-date"/>
                </VBox>
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Date de départ" styleClass="booking-label"/>
                    <DatePicker fx:id="checkOutPicker" promptText="Départ" styleClass="booking-date"/>
                </VBox>
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Voyageurs" styleClass="booking-label"/>
                    <ComboBox fx:id="guestCombo" promptText="Adulte" styleClass="booking-combo"/>
                </VBox>
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Chambres" styleClass="booking-label"/>
                    <ComboBox fx:id="roomCombo" promptText="1 chambre" styleClass="booking-combo"/>
                </VBox>
                <Button text="RÉSERVER MAINTENANT"
                        onAction="#handleBookNow"
                        styleClass="btn-theme btn-book"/>
            </HBox>
        </VBox>

        <!-- ══ ACCOMMODATION AREA ════════════════════════════════ -->
        <VBox styleClass="section-gap" spacing="32" alignment="CENTER"
              style="-fx-background-color: white;">
            <VBox alignment="CENTER" spacing="10">
                <Label text="Hébergements 5 Étoiles" styleClass="section-title"/>
                <Label text="Découvrez nos établissements d'exception en Tunisie."
                       styleClass="section-sub"/>
            </VBox>
            <HBox spacing="24" alignment="CENTER" fx:id="roomsContainer"/>
        </VBox>

        <!-- ══ FACILITIES AREA ════════════════════════════════════ -->
        <VBox styleClass="facilities-area" spacing="32" alignment="CENTER">
            <padding>
                <Insets top="70" bottom="70" left="80" right="80"/>
            </padding>
            <VBox alignment="CENTER" spacing="10">
                <Label text="Services de luxe" styleClass="section-title-white"/>
                <Label text="Pour ceux qui aiment mélanger entre les voyages de luxe et les aventures en pleine nature."
                       styleClass="section-sub-white" wrapText="true"/>
            </VBox>
            <GridPane hgap="24" vgap="24" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                </columnConstraints>
                <VBox styleClass="facility-item" GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="12">
                    <Label text="🍽" styleClass="facility-icon"/>
                    <Label text="Restaurant" styleClass="facility-title"/>
                    <Label text="Profitez de restaurants de haute qualité proposant une cuisine locale et internationale."
                           styleClass="facility-desc" wrapText="true"/>
                </VBox>
                <VBox styleClass="facility-item" GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="12">
                    <Label text="🏊" styleClass="facility-icon"/>
                    <Label text="Piscine" styleClass="facility-title"/>
                    <Label text="Détendez-vous dans des piscines luxueuses avec une vue magnifique."
                           styleClass="facility-desc" wrapText="true"/>
                </VBox>
                <VBox styleClass="facility-item" GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="12">
                    <Label text="🚌" styleClass="facility-icon"/>
                    <Label text="Transport" styleClass="facility-title"/>
                    <Label text="Un service de transport disponible pour faciliter vos déplacements."
                           styleClass="facility-desc" wrapText="true"/>
                </VBox>
                <VBox styleClass="facility-item" GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="12">
                    <Label text="🛍" styleClass="facility-icon"/>
                    <Label text="Boutique" styleClass="facility-title"/>
                    <Label text="Des boutiques spécialisées avec tout le matériel pour votre voyage."
                           styleClass="facility-desc" wrapText="true"/>
                </VBox>
                <VBox styleClass="facility-item" GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="12">
                    <Label text="🏔" styleClass="facility-icon"/>
                    <Label text="Aventures" styleClass="facility-title"/>
                    <Label text="Destinations naturelles : montagne, mer, désert et plages vierges."
                           styleClass="facility-desc" wrapText="true"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- ══ ABOUT AREA ════════════════════════════════════════ -->
        <HBox styleClass="section-gap about-area" spacing="48" alignment="CENTER">
            <VBox spacing="20" HBox.hgrow="ALWAYS" maxWidth="480">
                <Label text="À PROPOS" styleClass="about-overtitle"/>
                <Label text="Notre histoire &amp; Mission" styleClass="about-title" wrapText="true"/>
                <Label text="Notre site offre des voyages de luxe et des aventures. Notre objectif est d'offrir une expérience unique qui combine confort et découverte de l'environnement. La Tunisie est un pays riche en paysages naturels : plages vierges, montagnes, désert et sites touristiques exceptionnels."
                       styleClass="about-desc" wrapText="true"/>
                <Button text="Découvrir" onAction="#handleDecouvrir" styleClass="btn-theme-outline"/>
            </VBox>
            <Rectangle fx:id="aboutImage"
                       width="420" height="300"
                       styleClass="about-image-placeholder"
                       arcWidth="20" arcHeight="20"/>
        </HBox>

        <!-- ══ TESTIMONIALS ══════════════════════════════════════ -->
        <VBox styleClass="section-gap" spacing="32" alignment="CENTER"
              style="-fx-background-color: #f8faf5;">
            <VBox alignment="CENTER" spacing="10">
                <Label text="Témoignages de nos clients" styleClass="section-title"/>
                <Label text="Découvrez ce que nos clients pensent de nos services."
                       styleClass="section-sub"/>
            </VBox>
            <HBox fx:id="testimonialsContainer" spacing="24" alignment="CENTER"/>
        </VBox>

        <fx:include source="../components/front-footer.fxml"/>

    </VBox>
</ScrollPane>