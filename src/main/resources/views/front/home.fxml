<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controller.front.HomeController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="front-scroll">

    <VBox spacing="0" styleClass="home2-page">
        <HBox spacing="34" styleClass="home2-hero">
            <VBox spacing="18" HBox.hgrow="ALWAYS" maxWidth="700">
                <Label text="ECOTRIP" styleClass="home2-chip"/>
                <Label text="Travel better. Explore Tunisia with purpose." styleClass="home2-title" wrapText="true"/>
                <Label text="Plan accommodation, activities, transport, and shopping in one modern eco platform."
                       styleClass="home2-subtitle"
                       wrapText="true"/>
                <HBox spacing="12">
                    <Button text="Start trip planning" onAction="#handleCommencer" styleClass="btn-theme"/>
                    <Button text="Learn more" onAction="#handleDecouvrir" styleClass="btn-outline-modern"/>
                </HBox>
                <HBox spacing="14" styleClass="home2-badges">
                    <Label text="♻ Sustainable stays" styleClass="home2-badge"/>
                    <Label text="🧭 Local experiences" styleClass="home2-badge"/>
                    <Label text="🚌 Smart transport" styleClass="home2-badge"/>
                </HBox>
            </VBox>

            <VBox spacing="14" styleClass="home2-booking-card" maxWidth="430">
                <Label text="Quick planner" styleClass="home2-booking-title"/>
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Check-in" styleClass="home2-booking-label"/>
                        <DatePicker fx:id="checkInPicker" promptText="Date"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Check-out" styleClass="home2-booking-label"/>
                        <DatePicker fx:id="checkOutPicker" promptText="Date"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="Travelers" styleClass="home2-booking-label"/>
                        <ComboBox fx:id="guestCombo" promptText="Guests"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="Rooms" styleClass="home2-booking-label"/>
                        <ComboBox fx:id="roomCombo" promptText="Rooms"/>
                    </VBox>
                </GridPane>
                <Button text="Search options" onAction="#handleBookNow" styleClass="btn-primary-modern"/>
            </VBox>
        </HBox>

        <VBox spacing="26" styleClass="home2-section">
            <VBox spacing="8" alignment="CENTER">
                <Label text="Core Services" styleClass="section-title"/>
                <Label text="Everything you need in one interface." styleClass="section-sub"/>
            </VBox>
            <GridPane hgap="18" vgap="18" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>
                <VBox styleClass="home2-service-card" spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="🏨" styleClass="home2-service-icon"/>
                    <Label text="Accommodation" styleClass="home2-service-title"/>
                    <Label text="Curated eco stays and transparent booking flow." wrapText="true" styleClass="home2-service-desc"/>
                </VBox>
                <VBox styleClass="home2-service-card" spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="🥾" styleClass="home2-service-icon"/>
                    <Label text="Activities" styleClass="home2-service-title"/>
                    <Label text="Nature, adventure, and local culture experiences." wrapText="true" styleClass="home2-service-desc"/>
                </VBox>
                <VBox styleClass="home2-service-card" spacing="7" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label text="🚌" styleClass="home2-service-icon"/>
                    <Label text="Transport" styleClass="home2-service-title"/>
                    <Label text="Connected routes and smoother itinerary management." wrapText="true" styleClass="home2-service-desc"/>
                </VBox>
                <VBox styleClass="home2-service-card" spacing="7" GridPane.columnIndex="3" GridPane.rowIndex="0">
                    <Label text="🛍" styleClass="home2-service-icon"/>
                    <Label text="Shopping" styleClass="home2-service-title"/>
                    <Label text="Support local producers with conscious purchases." wrapText="true" styleClass="home2-service-desc"/>
                </VBox>
            </GridPane>
        </VBox>

        <HBox spacing="22" styleClass="home2-values">
            <VBox HBox.hgrow="ALWAYS" spacing="8" styleClass="home2-value-card">
                <Label text="Sustainability first" styleClass="home2-value-title"/>
                <Label text="Every recommendation aims to reduce environmental footprint." wrapText="true" styleClass="home2-value-desc"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="8" styleClass="home2-value-card">
                <Label text="Smart travel decisions" styleClass="home2-value-title"/>
                <Label text="Compare options quickly and make better travel choices." wrapText="true" styleClass="home2-value-desc"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="8" styleClass="home2-value-card">
                <Label text="Positive local impact" styleClass="home2-value-title"/>
                <Label text="Promote fair tourism and community-based experiences." wrapText="true" styleClass="home2-value-desc"/>
            </VBox>
        </HBox>

        <VBox spacing="22" styleClass="home2-section">
            <VBox spacing="8" alignment="CENTER">
                <Label text="Popular stays" styleClass="section-title"/>
                <Label text="Handpicked places travelers love." styleClass="section-sub"/>
            </VBox>
            <HBox fx:id="roomsContainer" spacing="20" alignment="CENTER"/>
        </VBox>

        <HBox spacing="30" styleClass="home2-about">
            <VBox spacing="12" HBox.hgrow="ALWAYS" maxWidth="620">
                <Label text="Built for modern travelers" styleClass="about-overtitle"/>
                <Label text="A clean platform for responsible trips" styleClass="about-title" wrapText="true"/>
                <Label text="EcoTrip helps you move from inspiration to booking in minutes while keeping sustainability at the center."
                       styleClass="about-desc"
                       wrapText="true"/>
                <Button text="Discover the mission" onAction="#handleDecouvrir" styleClass="btn-primary-modern"/>
            </VBox>
            <Rectangle width="390" height="220" arcWidth="18" arcHeight="18" styleClass="about-image-placeholder"/>
        </HBox>

        <VBox spacing="22" styleClass="home2-section">
            <VBox spacing="8" alignment="CENTER">
                <Label text="Traveler reviews" styleClass="section-title"/>
                <Label text="What users say after booking with EcoTrip." styleClass="section-sub"/>
            </VBox>
            <HBox fx:id="testimonialsContainer" spacing="20" alignment="CENTER"/>
        </VBox>

        <fx:include source="/views/components/front-footer.fxml"/>
    </VBox>
</ScrollPane>
