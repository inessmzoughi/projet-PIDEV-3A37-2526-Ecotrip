<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controller.front.ProductsController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="front-scroll">

    <VBox styleClass="heb-page" spacing="0">

        <!-- ══ HERO ══ -->
        <VBox styleClass="heb-hero" alignment="CENTER" spacing="14">
            <padding><Insets top="80" bottom="80" left="40" right="40"/></padding>
            <Label text="Our Eco-Friendly Products" styleClass="heb-hero-title"/>
            <Label text="Explore our full catalogue of sustainable products" styleClass="heb-hero-sub"/>
        </VBox>

        <!-- ══ FILTRES ══ -->
        <VBox styleClass="heb-filters-container">
            <padding><Insets top="30" bottom="30" left="40" right="40"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
                <Region styleClass="filters-title-bar"/>
                <Label text="SEARCH &amp; FILTER PRODUCTS" styleClass="filters-section-title"/>
            </HBox>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Search by product name..."
                           styleClass="heb-filter-input"
                           HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="sortSelect" styleClass="heb-filter-input" prefWidth="180">
                    <items>
                        <javafx.collections.FXCollections fx:factory="observableArrayList">
                            <String fx:value="Sort by"/>
                            <String fx:value="Name (A-Z)"/>
                            <String fx:value="Name (Z-A)"/>
                            <String fx:value="Price (Low-High)"/>
                            <String fx:value="Price (High-Low)"/>
                        </javafx.collections.FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="filterCategory" styleClass="heb-filter-input" prefWidth="180"/>
                <Button text="Clear Filters" styleClass="heb-clear-btn" onAction="#onReset" prefWidth="140"/>
            </HBox>
        </VBox>

        <!-- ══ RÉSULTATS + BOUTON PANIER ══ -->
        <!-- ✅ SEUL CHANGEMENT : on ajoute le bouton panier à droite du resultCount -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets top="24" bottom="12" left="40" right="40"/></padding>
            <Label fx:id="resultCount" text="0 Product(s) Found" styleClass="heb-result-count"
                   HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnCart"
                    text="🛒  Mon Panier (0)"
                    onAction="#onOpenCart"
                    style="-fx-background-color: #2d5a1b;
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 10 20 10 20;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;"/>
        </HBox>

        <!-- ══ CARTES ══ -->
        <FlowPane fx:id="cardsPane" hgap="28" vgap="28" styleClass="heb-cards-pane">
            <padding><Insets top="0" bottom="40" left="40" right="40"/></padding>
        </FlowPane>

        <!-- ══ EMPTY STATE ══ -->
        <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
              managed="false" visible="false" styleClass="heb-empty">
            <padding><Insets top="60" bottom="60"/></padding>
            <Label text="🛒" styleClass="heb-empty-icon"/>
            <Label text="No Products Found" styleClass="heb-empty-title"/>
            <Label text="Try adjusting your filters to see more results" styleClass="heb-empty-sub"/>
            <Button text="↺  Reset Filters" styleClass="heb-clear-btn" onAction="#onReset"/>
        </VBox>

        <!-- ══ PAGINATION ══ -->
        <HBox fx:id="paginationBar" alignment="CENTER" spacing="16"
              managed="false" visible="false" styleClass="heb-pagination">
            <padding><Insets top="24" bottom="24" left="40" right="40"/></padding>
            <Button fx:id="btnPrev" text="← Précédent" styleClass="heb-page-btn" onAction="#onPrev"/>
            <Label fx:id="pagInfo" text="Page 1 / 1" styleClass="heb-page-info"/>
            <Button fx:id="btnNext" text="Suivant →" styleClass="heb-page-btn" onAction="#onNext"/>
        </HBox>


        <!-- ══ FOOTER ══ -->
        <fx:include source="../components/front-footer.fxml"/>

    </VBox>
</ScrollPane>