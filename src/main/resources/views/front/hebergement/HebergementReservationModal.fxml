<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controller.front.reservation.HebergementReservationController"
      styleClass="modal-overlay"
      alignment="CENTER">

    <VBox styleClass="modal-card" maxWidth="480" spacing="0">

        <!-- Header -->
        <HBox styleClass="modal-header" alignment="CENTER_LEFT" spacing="14">
            <Label text="🏨" style="-fx-font-size:22px;"/>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="Réserver" styleClass="modal-title"/>
                <Label fx:id="hebergementNameLabel" styleClass="modal-subtitle" wrapText="true"/>
            </VBox>
            <Button text="✕" styleClass="modal-close-btn" onAction="#onClose"/>
        </HBox>

        <!-- Body -->
        <VBox styleClass="modal-body" spacing="16">

            <!-- Success / Error -->
            <Label fx:id="errorLabel" styleClass="modal-error"
                   managed="false" visible="false" wrapText="true"/>

            <!-- Check-in -->
            <VBox spacing="6" styleClass="form-group">
                <Label text="📅  Date d'arrivée *" styleClass="form-label"/>
                <DatePicker fx:id="checkInPicker" styleClass="form-input" maxWidth="Infinity"
                            promptText="jj/mm/aaaa"/>
                <Label fx:id="errCheckIn" styleClass="err-msg" managed="false" visible="false"/>
            </VBox>

            <!-- Check-out -->
            <VBox spacing="6" styleClass="form-group">
                <Label text="📅  Date de départ *" styleClass="form-label"/>
                <DatePicker fx:id="checkOutPicker" styleClass="form-input" maxWidth="Infinity"
                            promptText="jj/mm/aaaa"/>
                <Label fx:id="errCheckOut" styleClass="err-msg" managed="false" visible="false"/>
            </VBox>

            <!-- Guests -->
            <VBox spacing="6" styleClass="form-group">
                <Label text="👥  Nombre de personnes *" styleClass="form-label"/>
                <Spinner fx:id="guestsSpinner" min="1" max="20" initialValue="1"
                         styleClass="form-input" maxWidth="Infinity" editable="true"/>
                <Label fx:id="errGuests" styleClass="err-msg" managed="false" visible="false"/>
            </VBox>

            <!-- Nights summary (auto-calculated) -->
            <HBox styleClass="modal-summary-box" spacing="10" alignment="CENTER_LEFT"
                  fx:id="summaryBox" managed="false" visible="false">
                <Label text="🌙" style="-fx-font-size:16px;"/>
                <Label fx:id="nightsLabel" styleClass="modal-summary-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalLabel" styleClass="modal-summary-price"/>
            </HBox>

        </VBox>

        <!-- Footer -->
        <HBox styleClass="modal-footer" alignment="CENTER_RIGHT" spacing="12">
            <Button text="Annuler" styleClass="btn-cancel" onAction="#onClose"/>
            <Button text="🛒  Ajouter au panier" styleClass="btn-submit"
                    onAction="#onAddToCart"/>
        </HBox>

    </VBox>
</VBox>