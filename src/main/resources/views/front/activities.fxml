<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<!-- Front-shell injects this into the scrollable content area -->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controller.front.ActivitiesController"
      spacing="0">

    <!-- ══ HERO BANNER ══════════════════════════════════════════ -->
    <VBox styleClass="act-hero" alignment="CENTER" spacing="16">
        <Label text="EXPLOREZ LA TUNISIE" styleClass="banner-sub"/>
        <Label text="Activités &amp; Aventures" styleClass="banner-title"/>
        <Label text="Randonnées, plongée, désert, culture — des expériences inoubliables avec des guides locaux certifiés."
               styleClass="banner-desc" wrapText="true"/>

        <!-- Search bar -->
        <HBox styleClass="act-search-bar" alignment="CENTER" spacing="12">
            <TextField fx:id="searchField"
                       promptText="🔍  Rechercher une activité..."
                       styleClass="act-search-input"
                       HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="sortCombo"
                      promptText="Trier par"
                      styleClass="act-sort-combo"/>
            <Button text="Rechercher"
                    onAction="#handleSearch"
                    styleClass="btn-theme"/>
        </HBox>
    </VBox>

    <!-- ══ CATEGORY FILTER TABS ════════════════════════════════ -->
    <HBox styleClass="act-tab-bar" alignment="CENTER_LEFT" spacing="8">
        <Button fx:id="tabAll"
                text="🌿  Toutes"
                onAction="#handleTabAll"
                styleClass="act-tab act-tab-active"/>
        <!-- Category tabs built dynamically in controller -->
        <HBox fx:id="categoryTabsBox" spacing="8" alignment="CENTER_LEFT"/>
    </HBox>

    <!-- ══ RESULTS COUNT + ACTIVE FILTER INFO ══════════════════ -->
    <HBox styleClass="act-results-bar" alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="resultsCountLabel" text="Chargement..." styleClass="act-results-count"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="activeFilterLabel" text="" styleClass="act-filter-badge" visible="false" managed="false"/>
        <Button fx:id="clearFilterBtn" text="✕  Effacer filtre"
                onAction="#handleClearFilter"
                styleClass="act-clear-btn" visible="false" managed="false"/>
    </HBox>

    <!-- ══ MAIN CONTENT AREA ═══════════════════════════════════ -->
    <HBox styleClass="act-main" spacing="24" VBox.vgrow="ALWAYS">

        <!-- ── Sidebar filters ──────────────────────────────── -->
        <VBox styleClass="act-sidebar" spacing="20" minWidth="220" maxWidth="220">

            <!-- Price range -->
            <VBox spacing="10">
                <Label text="💰  Prix maximum" styleClass="act-filter-title"/>
                <Slider fx:id="priceSlider"
                        min="0" max="500" value="500"
                        showTickLabels="true" showTickMarks="true"
                        majorTickUnit="100"
                        styleClass="act-slider"/>
                <HBox alignment="CENTER" spacing="8">
                    <Label text="0 TND" styleClass="act-filter-hint"/>
                    <Label fx:id="priceLabel" text="500 TND" styleClass="act-filter-value"/>
                </HBox>
            </VBox>

            <Separator styleClass="act-separator"/>

            <!-- Duration -->
            <VBox spacing="10">
                <Label text="⏱  Durée" styleClass="act-filter-title"/>
                <VBox fx:id="durationBox" spacing="8">
                    <RadioButton fx:id="durAll"   text="Toutes durées"   styleClass="act-radio" selected="true"/>
                    <RadioButton fx:id="durShort" text="Moins de 2h"     styleClass="act-radio"/>
                    <RadioButton fx:id="durMed"   text="2h – 4h"         styleClass="act-radio"/>
                    <RadioButton fx:id="durLong"  text="Plus de 4h"      styleClass="act-radio"/>
                </VBox>
            </VBox>

            <Separator styleClass="act-separator"/>

            <!-- Participants -->
            <VBox spacing="10">
                <Label text="👥  Participants" styleClass="act-filter-title"/>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Min :" styleClass="act-filter-hint"/>
                    <Spinner fx:id="participantsSpinner"
                             min="1" max="50" initialValue="1"
                             editable="true"
                             styleClass="act-spinner"
                             prefWidth="80"/>
                </HBox>
            </VBox>

            <Separator styleClass="act-separator"/>

            <!-- Apply filters button -->
            <Button text="Appliquer les filtres"
                    onAction="#handleApplyFilters"
                    styleClass="btn-theme"
                    maxWidth="Infinity"/>
            <Button text="Réinitialiser"
                    onAction="#handleResetFilters"
                    styleClass="btn-theme-outline"
                    maxWidth="Infinity"/>
        </VBox>

        <!-- ── Activity cards grid ──────────────────────────── -->
        <VBox HBox.hgrow="ALWAYS" spacing="0">

            <!-- Empty state (hidden by default) -->
            <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
                  styleClass="act-empty-state" visible="false" managed="false">
                <Label text="🌵" styleClass="act-empty-icon"/>
                <Label text="Aucune activité trouvée" styleClass="act-empty-title"/>
                <Label text="Essayez de modifier vos filtres ou votre recherche."
                       styleClass="act-empty-sub" wrapText="true"/>
                <Button text="Voir toutes les activités"
                        onAction="#handleClearFilter"
                        styleClass="btn-theme-outline"/>
            </VBox>

            <!-- Cards grid — populated by controller -->
            <FlowPane fx:id="activitiesGrid"
                      styleClass="act-cards-grid"
                      hgap="20" vgap="20"
                      VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>

    <!-- ══ CTA SECTION ═════════════════════════════════════════ -->
    <VBox styleClass="act-cta-section" alignment="CENTER" spacing="16">
        <Label text="Vous ne trouvez pas ce que vous cherchez ?" styleClass="section-title-white"/>
        <Label text="Contactez-nous et nous créerons une expérience sur mesure pour vous."
               styleClass="section-sub-white" wrapText="true"/>
        <Button text="Nous contacter" onAction="#handleContact" styleClass="act-cta-btn"/>
    </VBox>

</VBox>