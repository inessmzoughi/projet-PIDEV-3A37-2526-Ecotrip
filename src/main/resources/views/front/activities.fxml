<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controller.front.ActivitiesController"
           styleClass="heb-page-shell">

    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="front-scroll">

        <VBox spacing="0" styleClass="heb-page">

            <VBox styleClass="heb-hero" alignment="CENTER" spacing="14">
                <padding><Insets top="80" bottom="80" left="40" right="40"/></padding>
                <Label text="Activites &amp; Aventures" styleClass="heb-hero-title"/>
                <Label text="Randonnees, plongee, desert, culture : des experiences inoubliables avec des guides locaux certifies."
                       styleClass="heb-hero-sub" wrapText="true"/>
            </VBox>


            <VBox styleClass="heb-filters-container">
                <padding><Insets top="30" bottom="30" left="40" right="40"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
                    <Region styleClass="filters-title-bar"/>
                    <Label text="RECHERCHER ET FILTRER LES ACTIVITES" styleClass="filters-section-title"/>
                </HBox>

                <VBox spacing="18">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField"
                                   promptText="Rechercher par titre ou lieu..."
                                   styleClass="heb-filter-input"
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="sortCombo"
                                  promptText="Trier par"
                                  styleClass="heb-filter-input"
                                  prefWidth="220"/>

                        <ComboBox fx:id="categoryCombo"
                                  promptText="categories"
                                  styleClass="heb-filter-input"
                                  prefWidth="220"/>

                        <Button text="Reinitialiser"
                                styleClass="heb-clear-btn"
                                onAction="#handleResetFilters"
                                prefWidth="160"/>
                    </HBox>

                </VBox>
            </VBox>

            <HBox alignment="CENTER_LEFT">
                <padding><Insets top="24" bottom="12" left="40" right="40"/></padding>
                <Label fx:id="resultsCountLabel" text="0 Activite(s) trouvee(s)" styleClass="heb-result-count"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="activeFilterLabel" text="" styleClass="act-filter-badge"
                       visible="false" managed="false"/>
                <Button fx:id="clearFilterBtn" text="✕ Effacer filtre"
                        onAction="#handleClearFilter"
                        styleClass="act-clear-btn" visible="false" managed="false"/>
            </HBox>

            <FlowPane fx:id="activitiesGrid" hgap="28" vgap="28" styleClass="heb-cards-pane">
                <padding><Insets top="0" bottom="20" left="40" right="40"/></padding>
            </FlowPane>

            <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
                  managed="false" visible="false" styleClass="heb-empty">
                <padding><Insets top="60" bottom="60"/></padding>
                <Label text="🌵" styleClass="heb-empty-icon"/>
                <Label text="Aucune activite trouvee" styleClass="heb-empty-title"/>
                <Label text="Essayez de modifier vos filtres pour voir plus de resultats"
                       styleClass="heb-empty-sub" wrapText="true"/>
                <Button text="↺ Reinitialiser les filtres" styleClass="heb-clear-btn"
                        onAction="#handleResetFilters"/>
            </VBox>

            <HBox fx:id="paginationBar" alignment="CENTER" spacing="16"
                  managed="false" visible="false" styleClass="heb-pagination">
                <padding><Insets top="24" bottom="24" left="40" right="40"/></padding>
                <Button fx:id="btnPrev" text="← Precedent" styleClass="heb-page-btn" onAction="#onPrev"/>
                <Label fx:id="pagInfo" text="Page 1 / 1" styleClass="heb-page-info"/>
                <Button fx:id="btnNext" text="Suivant →" styleClass="heb-page-btn" onAction="#onNext"/>
            </HBox>

            <fx:include source="../components/front-footer.fxml"/>

        </VBox>
    </ScrollPane>

    <Button fx:id="chatbotLauncher"
            text=" "
            onAction="#toggleChatbot"
            styleClass="activity-chatbot-fab"
            StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets right="28" bottom="32"/>
        </StackPane.margin>
    </Button>

    <VBox fx:id="chatbotPanel"
          visible="false"
          managed="false"
          spacing="0"
          styleClass="activity-chatbot-panel"
          StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets right="28" bottom="32"/>
        </StackPane.margin>

        <HBox styleClass="activity-chatbot-header" alignment="CENTER_LEFT" spacing="12">
            <Label text="🌿 EcoTrip Assistant" styleClass="activity-chatbot-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="−" onAction="#toggleChatbot" styleClass="activity-chatbot-min-btn"/>
        </HBox>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="activity-chatbot-scroll">
            <VBox spacing="14" styleClass="activity-chatbot-body">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <VBox spacing="8" styleClass="activity-chatbot-bubble">
                    <Label fx:id="chatbotGreetingLabel"
                           text="Salut ! Je suis ton assistant EcoTrip."
                           styleClass="activity-chatbot-message"
                           wrapText="true"/>
                    <Label fx:id="chatbotStatusLabel"
                           text="Dis-moi une ville, une categorie ou une ambiance et je te proposerai les meilleures activites."
                           styleClass="activity-chatbot-submessage"
                           wrapText="true"/>
                </VBox>

                <FlowPane hgap="8" vgap="8">
                    <Button text="Nature a Djerba" onAction="#handleChatbotNature" styleClass="activity-chatbot-chip"/>
                    <Button text="Culture a Tunis" onAction="#handleChatbotCulture" styleClass="activity-chatbot-chip"/>
                    <Button text="Aventure desert" onAction="#handleChatbotAdventure" styleClass="activity-chatbot-chip"/>
                </FlowPane>

                <VBox fx:id="chatbotSuggestionsBox" spacing="12"/>
            </VBox>
        </ScrollPane>

        <HBox styleClass="activity-chatbot-inputbar" alignment="CENTER_LEFT" spacing="10">
            <TextField fx:id="chatbotInputField"
                       promptText="Demande-moi n'importe quoi sur les activites..."
                       styleClass="activity-chatbot-input"
                       HBox.hgrow="ALWAYS"
                       onAction="#handleChatbotSend"/>
            <Button fx:id="chatbotSendBtn"
                    text="➤"
                    onAction="#handleChatbotSend"
                    styleClass="activity-chatbot-send-btn"/>
        </HBox>
    </VBox>

</StackPane>
