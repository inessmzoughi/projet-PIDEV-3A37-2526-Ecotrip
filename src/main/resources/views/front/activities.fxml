<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controller.front.ActivitiesController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="heb-scroll">

    <VBox spacing="0">

        <!-- ══ HERO ══ -->
        <VBox styleClass="heb-hero" alignment="CENTER" spacing="14">
            <padding><Insets top="80" bottom="80" left="40" right="40"/></padding>
            <Label text="Activités &amp; Aventures" styleClass="heb-hero-title"/>
            <Label text="Randonnées, plongée, désert, culture — des expériences inoubliables avec des guides locaux certifiés."
                   styleClass="heb-hero-sub" wrapText="true"/>
        </VBox>

        <!-- ══ CATEGORY FILTER TABS ══ -->
        <HBox styleClass="act-tab-bar" alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="16" bottom="16" left="40" right="40"/></padding>
            <Button fx:id="tabAll"
                    text="🌿  Toutes"
                    onAction="#handleTabAll"
                    styleClass="act-tab act-tab-active"/>
            <HBox fx:id="categoryTabsBox" spacing="8" alignment="CENTER_LEFT"/>
        </HBox>

        <!-- ══ FILTRES (identical to hebergement) ══ -->
        <VBox styleClass="heb-filters-container">
            <padding><Insets top="30" bottom="30" left="40" right="40"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
                <Region styleClass="filters-title-bar"/>
                <Label text="RECHERCHER ET FILTRER LES ACTIVITÉS" styleClass="filters-section-title"/>
            </HBox>
            <HBox spacing="16" alignment="CENTER_LEFT">

                <!-- Search -->
                <TextField fx:id="searchField"
                           promptText="Rechercher par titre ou lieu..."
                           styleClass="heb-filter-input"
                           HBox.hgrow="ALWAYS"/>

                <!-- Sort -->
                <ComboBox fx:id="sortCombo"
                          promptText="Trier par"
                          styleClass="heb-filter-input"
                          prefWidth="180">
                    <items>
                        <javafx.collections.FXCollections fx:factory="observableArrayList">
                            <String fx:value="Trier par"/>
                            <String fx:value="Prix croissant"/>
                            <String fx:value="Prix décroissant"/>
                            <String fx:value="Durée croissante"/>
                            <String fx:value="Alphabétique"/>
                        </javafx.collections.FXCollections>
                    </items>
                </ComboBox>

                <!-- Price slider -->
                <VBox spacing="4" minWidth="160">
                    <Label text="💰 Prix max" styleClass="act-filter-hint"/>
                    <Slider fx:id="priceSlider" min="0" max="500" value="500"
                            styleClass="act-slider" prefWidth="160"/>
                    <HBox spacing="6">
                        <Label text="0 TND" styleClass="act-filter-hint"/>
                        <Label fx:id="priceLabel" text="500 TND" styleClass="act-filter-value"/>
                    </HBox>
                </VBox>

                <!-- Duration -->
                <VBox spacing="4">
                    <Label text="⏱ Durée" styleClass="act-filter-hint"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <RadioButton fx:id="durAll"   text="Toutes"  styleClass="act-radio" selected="true"/>
                        <RadioButton fx:id="durShort" text="&lt; 2h" styleClass="act-radio"/>
                        <RadioButton fx:id="durMed"   text="2h–4h"   styleClass="act-radio"/>
                        <RadioButton fx:id="durLong"  text="&gt; 4h" styleClass="act-radio"/>
                    </HBox>
                </VBox>

                <!-- Participants -->
                <VBox spacing="4">
                    <Label text="👥 Participants min" styleClass="act-filter-hint"/>
                    <Spinner fx:id="participantsSpinner" min="1" max="50" initialValue="1"
                             editable="true" styleClass="act-spinner" prefWidth="80"/>
                </VBox>

                <!-- Reset button -->
                <Button text="Réinitialiser" styleClass="heb-clear-btn"
                        onAction="#handleResetFilters" prefWidth="130"/>

            </HBox>
        </VBox>

        <!-- ══ RÉSULTATS HEADER ══ -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets top="24" bottom="12" left="40" right="40"/></padding>
            <Label fx:id="resultsCountLabel" text="0 Activité(s) Trouvée(s)" styleClass="heb-result-count"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="activeFilterLabel" text="" styleClass="act-filter-badge"
                   visible="false" managed="false"/>
            <Button fx:id="clearFilterBtn" text="✕  Effacer filtre"
                    onAction="#handleClearFilter"
                    styleClass="act-clear-btn" visible="false" managed="false"/>
        </HBox>

        <!-- ══ CARTES ══ -->
        <FlowPane fx:id="activitiesGrid" hgap="28" vgap="28" styleClass="heb-cards-pane">
            <padding><Insets top="0" bottom="20" left="40" right="40"/></padding>
        </FlowPane>

        <!-- ══ EMPTY STATE ══ -->
        <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
              managed="false" visible="false" styleClass="heb-empty">
            <padding><Insets top="60" bottom="60"/></padding>
            <Label text="🌵" styleClass="heb-empty-icon"/>
            <Label text="Aucune Activité Trouvée" styleClass="heb-empty-title"/>
            <Label text="Essayez de modifier vos filtres pour voir plus de résultats"
                   styleClass="heb-empty-sub" wrapText="true"/>
            <Button text="↺  Réinitialiser les filtres" styleClass="heb-clear-btn"
                    onAction="#handleResetFilters"/>
        </VBox>

        <!-- ══ PAGINATION ══ -->
        <HBox fx:id="paginationBar" alignment="CENTER" spacing="16"
              managed="false" visible="false" styleClass="heb-pagination">
            <padding><Insets top="24" bottom="24" left="40" right="40"/></padding>
            <Button fx:id="btnPrev" text="← Précédent" styleClass="heb-page-btn" onAction="#onPrev"/>
            <Label fx:id="pagInfo" text="Page 1 / 1" styleClass="heb-page-info"/>
            <Button fx:id="btnNext" text="Suivant →" styleClass="heb-page-btn" onAction="#onNext"/>
        </HBox>

        <!-- ══ CTA ══ -->
        <VBox styleClass="act-cta-section" alignment="CENTER" spacing="16">
            <padding><Insets top="60" bottom="60" left="40" right="40"/></padding>
            <Label text="Vous ne trouvez pas ce que vous cherchez ?" styleClass="section-title-white"/>
            <Label text="Contactez-nous et nous créerons une expérience sur mesure pour vous."
                   styleClass="section-sub-white" wrapText="true"/>
            <Button text="Nous contacter" onAction="#handleContact" styleClass="act-cta-btn"/>
        </VBox>

        <!-- ══ FOOTER ══ -->
        <fx:include source="../components/front-footer.fxml"/>

    </VBox>
</ScrollPane>
