<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controller.front.ProductsController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="prod-scroll">

    <stylesheets>
        <String fx:value="@/styles/front.css"/>
    </stylesheets>

    <VBox styleClass="prod-page" spacing="0">

        <!-- ══ HERO ══ -->
        <VBox styleClass="prod-hero" alignment="CENTER" spacing="14">
            <padding><Insets top="80" bottom="80" left="40" right="40"/></padding>
            <Label text="Our Products" styleClass="prod-hero-title"/>
            <Label text="Explore our full catalogue of eco-friendly products" styleClass="prod-hero-sub"/>
        </VBox>

        <!-- ══ FILTRES ══ -->
        <VBox styleClass="prod-filters-container">
            <padding><Insets top="30" bottom="30" left="40" right="40"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
                <Region styleClass="filters-title-bar"/>
                <Label text="SEARCH &amp; FILTER PRODUCTS" styleClass="filters-section-title"/>
            </HBox>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Search by product name..."
                           styleClass="prod-filter-input"
                           HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="sortSelect" styleClass="prod-filter-input" prefWidth="180">
                    <items>
                        <javafx.collections.FXCollections fx:factory="observableArrayList">
                            <String fx:value="Sort by"/>
                            <String fx:value="Name (A-Z)"/>
                            <String fx:value="Name (Z-A)"/>
                            <String fx:value="Price (Low-High)"/>
                            <String fx:value="Price (High-Low)"/>
                        </javafx.collections.FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="filterCategory" styleClass="prod-filter-input" prefWidth="180"/>
                <Button text="Clear Filters" styleClass="prod-clear-btn" onAction="#onReset" prefWidth="140"/>
            </HBox>
        </VBox>

        <!-- ══ RÉSULTATS HEADER ══ -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets top="24" bottom="12" left="40" right="40"/></padding>
            <Label fx:id="resultCount" text="0 Product(s) Found" styleClass="prod-result-count"/>
        </HBox>

        <!-- ══ CARTES ══ -->
        <FlowPane fx:id="cardsPane" hgap="28" vgap="28" styleClass="prod-cards-pane">
            <padding><Insets top="0" bottom="20" left="40" right="40"/></padding>
        </FlowPane>

        <!-- ══ EMPTY STATE ══ -->
        <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
              managed="false" visible="false" styleClass="prod-empty">
            <padding><Insets top="60" bottom="60"/></padding>
            <Label text="🛒" styleClass="prod-empty-icon"/>
            <Label text="No Products Found" styleClass="prod-empty-title"/>
            <Label text="Try adjusting your filters to see more results" styleClass="prod-empty-sub"/>
            <Button text="↺  Reset Filters" styleClass="prod-clear-btn" onAction="#onReset"/>
        </VBox>

        <!-- ══ PAGINATION ══ -->
        <HBox fx:id="paginationBar"
              alignment="CENTER" spacing="16"
              managed="false" visible="false"
              styleClass="prod-pagination">
            <padding><Insets top="24" bottom="24" left="40" right="40"/></padding>
            <Button fx:id="btnPrev" text="← Précédent" styleClass="prod-page-btn" onAction="#onPrev"/>
            <Label fx:id="pagInfo" text="Page 1 / 1" styleClass="prod-page-info"/>
            <Button fx:id="btnNext" text="Suivant →" styleClass="prod-page-btn" onAction="#onNext"/>
        </HBox>

        <!-- ══ FOOTER ══ -->
        <fx:include source="../components/front-footer.fxml"/>

    </VBox>
</ScrollPane>