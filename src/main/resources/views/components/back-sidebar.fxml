<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.component.BackSidebarController"
      styleClass="admin-sidebar" prefWidth="240" spacing="0">

    <!-- Logo -->
    <VBox styleClass="sidebar-logo-wrap" alignment="CENTER">
        <Label text="🌿 EcoTrip Admin" styleClass="sidebar-logo-text"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="sidebar-scroll">
        <VBox styleClass="sidebar-nav" spacing="2">

            <!-- Dashboard -->
            <Button fx:id="dashboardBtn" text="🏠  Dashboard"
                    onAction="#handleDashboard"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>

            <!-- ACTIVITÉS -->
            <Label text="ACTIVITÉS" styleClass="sidebar-section-label"/>
            <Button fx:id="activitesBtn" text="📅  Activités"
                    onAction="#handleActivites"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>

            <!-- HÉBERGEMENTS -->
            <Label text="HÉBERGEMENTS" styleClass="sidebar-section-label"/>
            <Button fx:id="hebergementsBtn" text="🏨  Hébergements"
                    onAction="#handleHebergements"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="listHebergementsBtn" text="    📋  Liste"
                    onAction="#handleListHebergements"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>
            <Button fx:id="chambresBtn" text="    🛏  Chambres"
                    onAction="#handleChambres"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>
            <Button fx:id="equipementsBtn" text="    🔧  Équipements"
                    onAction="#handleEquipements"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>
            <Button fx:id="categoriesBtn" text="    🏷  Catégories"
                    onAction="#handleCategories"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>

            <!-- TRANSPORT -->
            <Label text="TRANSPORT" styleClass="sidebar-section-label"/>
            <Button fx:id="transportBtn" text="🚌  Transport"
                    onAction="#handleTransport"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>

            <!-- BOUTIQUE -->
            <Label text="BOUTIQUE" styleClass="sidebar-section-label"/>
            <Button fx:id="boutiqueBtn" text="🛍  Boutique"
                    onAction="#handleBoutique"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>

            <!-- RÉSERVATIONS -->
            <Label text="RÉSERVATIONS" styleClass="sidebar-section-label"/>
            <Button fx:id="reservationsBtn" text="📋  Réservations"
                    onAction="#handleReservations"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>

            <!-- UTILISATEURS -->
            <Label text="UTILISATEURS" styleClass="sidebar-section-label"/>
            <Button fx:id="usersBtn" text="👥  Utilisateurs"
                    onAction="#handleUsers"
                    styleClass="sidebar-btn" maxWidth="Infinity"/>

        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <VBox styleClass="sidebar-footer" spacing="6">
        <Button text="🌐  Voir le site" onAction="#handleViewSite"
                styleClass="sidebar-btn" maxWidth="Infinity"/>
        <Button text="⬅  Déconnexion" onAction="#handleLogout"
                styleClass="sidebar-btn-logout" maxWidth="Infinity"/>
    </VBox>

</VBox>