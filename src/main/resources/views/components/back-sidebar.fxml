<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="240" spacing="0" styleClass="admin-sidebar"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controller.component.BackSidebarController">

    <!-- Logo -->
    <VBox alignment="CENTER" styleClass="sidebar-logo-wrap">
        <Label styleClass="sidebar-logo-text" text="🌿 EcoTrip Admin" />
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="2" styleClass="sidebar-nav">

            <!-- Dashboard -->
            <Button fx:id="dashboardBtn" maxWidth="Infinity" onAction="#handleDashboard" styleClass="sidebar-btn" text="🏠  Dashboard" />

            <!-- ACTIVITÉS -->
            <VBox>
                <Button text="📂 ACTIVITÉS"
                        onAction="#toggleActivities"
                        styleClass="sidebar-section-btn"/>

                <VBox fx:id="activitiesBox" spacing="2" visible="false" managed="false">
                    <Button fx:id="activityCategoriesBtn" text="🏷 Catégories"
                            onAction="#handleActivityCategories"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="guidesBtn" text="🧭 Guides"
                            onAction="#handleGuides"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="schedulesBtn" text="📅 Plannings"
                            onAction="#handleSchedules"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="activitiesBtn" text="🏃 Activités"
                            onAction="#handleActivities"
                            styleClass="sidebar-level-1"/>
                </VBox>
            </VBox>
            <!-- HÉBERGEMENTS -->
            <VBox>
                <Button text="📂 HÉBERGEMENTS"
                        onAction="#toggleHebergements"
                        styleClass="sidebar-section-btn"/>

                <VBox fx:id="hebergementsBox" spacing="2" visible="false" managed="false">
                    <Button fx:id="listHebergementsBtn" text="🏨 Hébergements"
                            onAction="#handleListHebergements"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="chambresBtn" text="🛏 Chambres"
                            onAction="#handleChambres"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="equipementsBtn" text="🔧 Équipements"
                            onAction="#handleEquipements"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="categoriesBtn" text="🏷 Catégories"
                            onAction="#handleCategories"
                            styleClass="sidebar-level-1"/>
                </VBox>
            </VBox>

            <!-- BOUTIQUE -->
            <VBox>
                <Button text="📂 BOUTIQUE"
                        onAction="#toggleBoutique"
                        styleClass="sidebar-section-btn"/>

                <VBox fx:id="boutiqueBox" spacing="2" visible="false" managed="false">
                    <Button fx:id="boutiqueBtn1" text="🛒 Commandes"
                            onAction="#handleCommandes"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="boutiqueBtn2" text="🛍 Produits"
                            onAction="#handleProduits"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="boutiqueBtn3" text="📋 Lignes commande"
                            onAction="#handleLignesCommande"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="boutiqueBtn31" text="💳 Paiements"
                            onAction="#handlePaiements"
                            styleClass="sidebar-level-1"/>

                    <Button fx:id="boutiqueBtn321" text="🏷 Catégories produit"
                            onAction="#handleProductsCategory"
                            styleClass="sidebar-level-1"/>
                </VBox>
            </VBox>

            <!-- TRANSPORT -->
            <Label styleClass="sidebar-section-label" text="TRANSPORT" />
            <Button fx:id="transportBtn" maxWidth="Infinity" onAction="#handleTransport" styleClass="sidebar-btn" text="🚌  Transport" />

            <!-- RÉSERVATIONS -->
            <Label styleClass="sidebar-section-label" text="RÉSERVATIONS" />
            <Button fx:id="reservationsBtn" maxWidth="Infinity" onAction="#handleReservations" styleClass="sidebar-btn" text="📋  Réservations" />

            <!-- UTILISATEURS -->
            <Label styleClass="sidebar-section-label" text="UTILISATEURS" />
            <Button fx:id="usersBtn" maxWidth="Infinity" onAction="#handleUsers" styleClass="sidebar-btn" text="👥  Utilisateurs" />

        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <VBox spacing="6" styleClass="sidebar-footer">
        <Button maxWidth="Infinity"  onAction="#handleViewSite"  styleClass="sidebar-btn"        text="🌐  Voir le site" />
        <Button fx:id="monCompteBtn" onAction="#handleMonCompte" styleClass="sidebar-btn"        text="Mon Compte" />
        <Button maxWidth="Infinity"  onAction="#handleLogout"    styleClass="sidebar-btn-logout" text="⬅  Déconnexion" />
    </VBox>

</VBox>
