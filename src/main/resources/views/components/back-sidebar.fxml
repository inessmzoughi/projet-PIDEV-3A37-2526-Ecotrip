<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="240" spacing="0" styleClass="admin-sidebar" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controller.component.BackSidebarController">

    <!-- Logo -->
    <VBox alignment="CENTER" styleClass="sidebar-logo-wrap">
        <Label styleClass="sidebar-logo-text" text="🌿 EcoTrip Admin" />
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="2" styleClass="sidebar-nav">

            <!-- Dashboard -->
            <Button fx:id="dashboardBtn" maxWidth="Infinity" onAction="#handleDashboard" styleClass="sidebar-btn" text="🏠  Dashboard" />

            <!-- ACTIVITÉS -->
            <Label text="ACTIVITÉS" styleClass="sidebar-section-label"/>
            <Button fx:id="activityCategoriesBtn" text="    🏷  Catégories"
                    onAction="#handleActivityCategories"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>
            <Button fx:id="guidesBtn" text="    🧭  Guides"
                    onAction="#handleGuides"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>
            <Button fx:id="schedulesBtn" text="    📅  Plannings"
                    onAction="#handleSchedules"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>
            <Button fx:id="activitiesBtn" text="    🏃  Activités"
                    onAction="#handleActivities"
                    styleClass="sidebar-btn sidebar-btn-sub" maxWidth="Infinity"/>
            <!-- HÉBERGEMENTS -->
            <Label styleClass="sidebar-section-label" text="HÉBERGEMENTS" />
            <Button fx:id="listHebergementsBtn" maxWidth="Infinity" onAction="#handleListHebergements" styleClass="sidebar-btn" text="🏨  Hébergements" />
            <Button fx:id="chambresBtn"         maxWidth="Infinity" onAction="#handleChambres"         styleClass="sidebar-sub-btn" text="🛏  Chambres" />
            <Button fx:id="equipementsBtn"      maxWidth="Infinity" onAction="#handleEquipements"      styleClass="sidebar-sub-btn" text="🔧  Équipements" />
            <Button fx:id="categoriesBtn"       maxWidth="Infinity" onAction="#handleCategories"       styleClass="sidebar-sub-btn" text="🏷  Catégories" />

            <!-- TRANSPORT -->
            <Label styleClass="sidebar-section-label" text="TRANSPORT" />
            <Button fx:id="transportBtn" maxWidth="Infinity" onAction="#handleTransport" styleClass="sidebar-btn" text="🚌  Transport" />

            <!-- BOUTIQUE -->
            <Label styleClass="sidebar-section-label" text="BOUTIQUE" />
            <Button fx:id="boutiqueBtn1"   maxWidth="Infinity" onAction="#handleCommandes"       styleClass="sidebar-btn" text="🛒  Commandes" />
            <Button fx:id="boutiqueBtn2"   maxWidth="Infinity" onAction="#handleProduits"         styleClass="sidebar-btn" text="🛍  Produits" />
            <Button fx:id="boutiqueBtn3"   maxWidth="Infinity" onAction="#handleLignesCommande"   styleClass="sidebar-btn" text="📋  Lignes commande" />
            <Button fx:id="boutiqueBtn31"  maxWidth="Infinity" onAction="#handlePaiements"        styleClass="sidebar-btn" text="💳  Paiements" />
            <Button fx:id="boutiqueBtn321" maxWidth="Infinity" onAction="#handleProductsCategory" styleClass="sidebar-btn" text="💳  Catégories produit" />

            <!-- RÉSERVATIONS -->
            <Label styleClass="sidebar-section-label" text="RÉSERVATIONS" />
            <Button fx:id="reservationsBtn" maxWidth="Infinity" onAction="#handleReservations" styleClass="sidebar-btn" text="📋  Réservations" />

            <!-- UTILISATEURS -->
            <Label styleClass="sidebar-section-label" text="UTILISATEURS" />
            <Button fx:id="usersBtn" maxWidth="Infinity" onAction="#handleUsers" styleClass="sidebar-btn" text="👥  Utilisateurs" />

        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <VBox spacing="6" styleClass="sidebar-footer">
        <Button maxWidth="Infinity"  onAction="#handleViewSite"  styleClass="sidebar-btn"        text="🌐  Voir le site" />
        <Button fx:id="monCompteBtn" onAction="#handleMonCompte" styleClass="sidebar-btn"        text="Mon Compte" />
        <Button maxWidth="Infinity"  onAction="#handleLogout"    styleClass="sidebar-btn-logout" text="⬅  Déconnexion" />
    </VBox>

</VBox>
