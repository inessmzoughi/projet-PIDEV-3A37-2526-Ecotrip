<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.auth.LoginController"
      spacing="15" alignment="CENTER"
      styleClass="login-container">

    <Label text="Welcome to EcoTrip" styleClass="title-label"/>

    <TextField fx:id="emailField" promptText="Email"/>
    <PasswordField fx:id="passwordField" promptText="Password"/>

    <Label fx:id="errorLabel" styleClass="error-label"/>

    <Button text="Login" onAction="#handleLogin" styleClass="btn-primary"/>
    <Button text="Register" onAction="#handleRegister" styleClass="btn-secondary"/>
</VBox>
