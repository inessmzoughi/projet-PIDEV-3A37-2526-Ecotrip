<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controller.compte.MonCompteController"
            styleClass="root-pane">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body moncompte-page" spacing="0">
                    <padding><Insets top="28" right="32" bottom="36" left="32"/></padding>

                    <!-- Hero -->
                    <VBox styleClass="moncompte-hero" spacing="8">
                        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
                        <Label text="🌿 Votre espace personnel" styleClass="moncompte-hero-kicker"/>
                        <Label text="Gérez votre profil et la sécurité de votre compte EcoTrip." styleClass="moncompte-hero-title" wrapText="true"/>
                        <Label text="Les modifications sont enregistrées immédiatement." styleClass="moncompte-hero-sub" wrapText="true"/>
                    </VBox>

                    <VBox spacing="20" styleClass="moncompte-below-hero">
                        <VBox.margin><Insets top="24"/></VBox.margin>

                        <!-- Breadcrumb -->
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Button text="Tableau de bord" styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Label text="Mon compte" styleClass="breadcrumb-active"/>
                        </HBox>

                        <!-- Toast -->
                        <Label fx:id="toastLabel" styleClass="toast-success"
                               managed="false" visible="false" wrapText="true"/>

                        <HBox spacing="28" alignment="TOP_LEFT" styleClass="moncompte-columns">

                            <!-- LEFT: profile + actions -->
                            <VBox minWidth="300" maxWidth="320" spacing="18" styleClass="moncompte-sidebar">

                                <VBox styleClass="form-card moncompte-profile-card" spacing="0" alignment="CENTER">
                                    <VBox styleClass="profile-avatar-section" spacing="12" alignment="CENTER">
                                        <padding><Insets top="28" right="20" bottom="20" left="20"/></padding>

                                        <StackPane alignment="CENTER" styleClass="moncompte-avatar-wrap">
                                            <Circle fx:id="avatarCircle" radius="52" styleClass="avatar-circle"/>
                                            <Label fx:id="avatarInitials" styleClass="avatar-initials"/>
                                            <ImageView fx:id="avatarPhoto"
                                                       fitWidth="104" fitHeight="104"
                                                       preserveRatio="true" smooth="true"
                                                       managed="true" visible="false"
                                                       style="-fx-background-radius:52;">
                                                <clip>
                                                    <Circle centerX="52" centerY="52" radius="52"/>
                                                </clip>
                                            </ImageView>
                                        </StackPane>

                                        <VBox spacing="6" alignment="CENTER">
                                            <Label fx:id="profileUsername" styleClass="profile-name"/>
                                            <Label fx:id="profileEmail" styleClass="profile-email"/>
                                            <HBox spacing="8" alignment="CENTER">
                                                <Label fx:id="roleValue" styleClass="badge-user"/>
                                                <Label fx:id="verifiedValue" styleClass="badge-actif"/>
                                            </HBox>
                                        </VBox>
                                    </VBox>

                                    <VBox styleClass="profile-info-rows" spacing="0">
                                        <HBox styleClass="profile-info-row" spacing="12" alignment="CENTER_LEFT">
                                            <Label text="📍" style="-fx-font-size:14px;"/>
                                            <Label fx:id="addressValue" styleClass="profile-info-value" wrapText="true"/>
                                        </HBox>
                                        <HBox styleClass="profile-info-row profile-info-row-last" spacing="12" alignment="CENTER_LEFT">
                                            <Label text="📞" style="-fx-font-size:14px;"/>
                                            <Label fx:id="phoneValue" styleClass="profile-info-value"/>
                                        </HBox>
                                    </VBox>
                                </VBox>

                                <VBox styleClass="form-card moncompte-actions-card" spacing="0">
                                    <Label text="Raccourcis" styleClass="profile-section-title"/>
                                    <VBox spacing="0">
                                        <Button text="✏  Modifier le profil"
                                                onAction="#showEditForm"
                                                styleClass="profile-action-btn" maxWidth="Infinity"/>
                                        <Separator/>
                                        <Button text="🔒  Changer le mot de passe"
                                                onAction="#showPasswordForm"
                                                styleClass="profile-action-btn" maxWidth="Infinity"/>
                                        <Separator/>
                                        <Button text="📷  Reconnaissance faciale"
                                                styleClass="profile-action-btn-disabled" maxWidth="Infinity"
                                                disable="true"/>
                                    </VBox>
                                </VBox>
                            </VBox>

                            <!-- RIGHT: forms -->
                            <VBox HBox.hgrow="ALWAYS" spacing="18" styleClass="moncompte-forms">

                                <VBox fx:id="editFormPanel" styleClass="form-card moncompte-form-card" spacing="0"
                                      managed="true" visible="true">
                                    <HBox styleClass="form-card-header" alignment="CENTER_LEFT" spacing="14">
                                        <Label text="✏️" styleClass="form-icon"/>
                                        <VBox spacing="4">
                                            <Label text="Modifier le profil" styleClass="form-heading-title"/>
                                            <Label text="Nom, e-mail, adresse et photo de profil." styleClass="form-heading-sub"/>
                                        </VBox>
                                    </HBox>
                                    <VBox styleClass="form-body" spacing="16">
                                        <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>

                                        <Label fx:id="editSuccessLabel" styleClass="toast-success"
                                               managed="false" visible="false" wrapText="true"/>

                                        <VBox spacing="10" styleClass="form-group">
                                            <Label text="Photo de profil" styleClass="form-label"/>
                                            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="moncompte-photo-row">
                                                <ImageView fx:id="photoPreview"
                                                           fitWidth="64" fitHeight="64"
                                                           preserveRatio="true"
                                                           styleClass="photo-preview"/>
                                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                    <Button text="Choisir une image"
                                                            styleClass="photo-upload-btn"
                                                            onAction="#onChoosePhoto"/>
                                                    <Label fx:id="photoLabel" text="Aucune photo sélectionnée"
                                                           styleClass="card-subtitle"/>
                                                </VBox>
                                            </HBox>
                                        </VBox>

                                        <HBox spacing="18">
                                            <VBox spacing="6" styleClass="form-group" HBox.hgrow="ALWAYS">
                                                <Label text="Nom d'utilisateur *" styleClass="form-label"/>
                                                <TextField fx:id="usernameField" styleClass="form-input"
                                                           promptText="votre_nom" onKeyReleased="#validateUsername"/>
                                                <Label fx:id="errUsername" text="Nom requis."
                                                       styleClass="err-msg" managed="false" visible="false"/>
                                            </VBox>
                                            <VBox spacing="6" styleClass="form-group" HBox.hgrow="ALWAYS">
                                                <Label text="E-mail *" styleClass="form-label"/>
                                                <TextField fx:id="emailField" styleClass="form-input"
                                                           promptText="email@exemple.com" onKeyReleased="#validateEmail"/>
                                                <Label fx:id="errEmail" text="E-mail invalide."
                                                       styleClass="err-msg" managed="false" visible="false"/>
                                            </VBox>
                                        </HBox>

                                        <HBox spacing="18">
                                            <VBox spacing="6" styleClass="form-group" HBox.hgrow="ALWAYS">
                                                <Label text="Adresse" styleClass="form-label"/>
                                                <TextField fx:id="addressField" styleClass="form-input"
                                                           promptText="Adresse complète"/>
                                            </VBox>
                                            <VBox spacing="6" styleClass="form-group" HBox.hgrow="ALWAYS">
                                                <Label text="Téléphone" styleClass="form-label"/>
                                                <TextField fx:id="phoneField" styleClass="form-input"
                                                           promptText="+216 XX XXX XXX"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                    <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="12">
                                        <Button text="Annuler" styleClass="btn-cancel" onAction="#cancelEdit"/>
                                        <Button text="Enregistrer" styleClass="btn-submit" onAction="#handleSaveProfile"/>
                                    </HBox>
                                </VBox>

                                <VBox fx:id="passwordFormPanel" styleClass="form-card moncompte-form-card" spacing="0"
                                      managed="false" visible="false">
                                    <HBox styleClass="form-card-header-blue" alignment="CENTER_LEFT" spacing="14">
                                        <Label text="🔒" styleClass="form-icon"/>
                                        <VBox spacing="4">
                                            <Label text="Mot de passe" styleClass="form-heading-title"/>
                                            <Label text="Utilisez un mot de passe long et unique." styleClass="form-heading-sub"/>
                                        </VBox>
                                    </HBox>
                                    <VBox styleClass="form-body" spacing="16">
                                        <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>

                                        <Label fx:id="passSuccessLabel" styleClass="toast-success"
                                               managed="false" visible="false" wrapText="true"/>

                                        <HBox styleClass="security-tip" spacing="10" alignment="CENTER_LEFT">
                                            <Label text="ℹ" style="-fx-font-size:14px; -fx-text-fill:#0284c7;"/>
                                            <Label text="Au moins 6 caractères. Mélangez lettres, chiffres et symboles."
                                                   styleClass="security-tip-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                                        </HBox>

                                        <VBox spacing="6" styleClass="form-group">
                                            <Label text="Mot de passe actuel *" styleClass="form-label"/>
                                            <PasswordField fx:id="currentPasswordField" styleClass="form-input"
                                                           promptText="••••••••"/>
                                            <Label fx:id="errCurrentPassword" styleClass="err-msg"
                                                   managed="false" visible="false"/>
                                        </VBox>
                                        <HBox spacing="18">
                                            <VBox spacing="6" styleClass="form-group" HBox.hgrow="ALWAYS">
                                                <Label text="Nouveau mot de passe *" styleClass="form-label"/>
                                                <PasswordField fx:id="newPasswordField" styleClass="form-input"
                                                               promptText="••••••••"/>
                                                <Label fx:id="errNewPassword" styleClass="err-msg"
                                                       managed="false" visible="false"/>
                                            </VBox>
                                            <VBox spacing="6" styleClass="form-group" HBox.hgrow="ALWAYS">
                                                <Label text="Confirmer *" styleClass="form-label"/>
                                                <PasswordField fx:id="confirmPasswordField" styleClass="form-input"
                                                               promptText="••••••••"/>
                                                <Label fx:id="errConfirmPassword" styleClass="err-msg"
                                                       managed="false" visible="false"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                    <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="12">
                                        <Button text="Annuler" styleClass="btn-cancel" onAction="#cancelPassword"/>
                                        <Button text="Mettre à jour" styleClass="btn-submit-blue" onAction="#handleSavePassword"/>
                                    </HBox>
                                </VBox>

                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
