<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controller.compte.UpdateAccountController"
      styleClass="profile-page" alignment="TOP_CENTER">

    <VBox styleClass="form-panel" maxWidth="720">

        <!-- Panel header — green gradient like the web -->
        <VBox styleClass="form-panel-header" spacing="6">
            <Label text="✏ Informations personnelles" styleClass="form-panel-title"/>
            <Label text="Mettez à jour vos coordonnées et votre photo de profil"
                   styleClass="form-panel-subtitle"/>
        </VBox>

        <!-- Panel body -->
        <VBox styleClass="form-panel-body" spacing="20">

            <!-- Success message (hidden by default) -->
            <Label fx:id="successLabel"
                   styleClass="alert-success"
                   managed="false" visible="false" wrapText="true"/>

            <!-- Email + Username row -->
            <GridPane hgap="20" >
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox styleClass="form-group" spacing="8" GridPane.columnIndex="0">
                    <Label text="Email" styleClass="form-field-label"/>
                    <TextField fx:id="emailField" styleClass="form-input"
                               promptText="votre@email.com"/>
                    <Label fx:id="emailError" styleClass="field-error"
                           managed="false" visible="false"/>
                </VBox>
                <VBox styleClass="form-group" spacing="8" GridPane.columnIndex="1">
                    <Label text="Nom d'utilisateur" styleClass="form-field-label"/>
                    <TextField fx:id="usernameField" styleClass="form-input"
                               promptText="Votre nom"/>
                    <Label fx:id="usernameError" styleClass="field-error"
                           managed="false" visible="false"/>
                </VBox>
            </GridPane>

            <!-- Address -->
            <VBox styleClass="form-group" spacing="8">
                <Label text="Adresse" styleClass="form-field-label"/>
                <TextField fx:id="addressField" styleClass="form-input"
                           promptText="Adresse complète"/>
            </VBox>

            <!-- Phone + Photo row -->
            <GridPane hgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox styleClass="form-group" spacing="8" GridPane.columnIndex="0">
                    <Label text="Téléphone" styleClass="form-field-label"/>
                    <TextField fx:id="phoneField" styleClass="form-input"
                               promptText="+216 XX XXX XXX"/>
                </VBox>
                <!-- Photo upload placeholder -->
                <VBox styleClass="form-group" spacing="8" GridPane.columnIndex="1">
                    <Label text="Photo de profil" styleClass="form-field-label"/>
                    <VBox styleClass="file-upload-box" spacing="8" alignment="CENTER">
                        <Label text="📤" style="-fx-font-size:24px;"/>
                        <Label text="Cliquer pour choisir une image" styleClass="file-upload-hint"/>
                        <Button text="Parcourir..." onAction="#handleSelectPhoto"
                                styleClass="btn-outline-modern"/>
                    </VBox>
                </VBox>
            </GridPane>

            <!-- Action buttons -->
            <HBox spacing="16" style="-fx-padding: 8 0 0 0;">
                <Button text="💾  Enregistrer les modifications"
                        onAction="#handleSave"
                        styleClass="btn-primary-modern"/>
                <Button text="Annuler"
                        onAction="#handleCancel"
                        styleClass="btn-outline-modern"/>
            </HBox>

        </VBox>
    </VBox>
</VBox>