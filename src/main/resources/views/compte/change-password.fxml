<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controller.compte.ChangePasswordController"
      styleClass="profile-page" alignment="TOP_CENTER">

    <VBox styleClass="password-panel" maxWidth="480">

        <!-- Blue header — matches the web -->
        <VBox styleClass="password-panel-header" spacing="8" alignment="CENTER">
            <StackPane styleClass="password-icon-wrap">
                <Label text="🛡" style="-fx-font-size:28px;"/>
            </StackPane>
            <Label text="Changer le mot de passe" styleClass="password-panel-title"/>
            <Label text="Choisissez un mot de passe fort pour protéger votre compte"
                   styleClass="password-panel-subtitle" wrapText="true"/>
        </VBox>

        <!-- Body -->
        <VBox styleClass="form-panel-body" spacing="20">

            <!-- Success -->
            <Label fx:id="successLabel" styleClass="alert-success"
                   managed="false" visible="false" wrapText="true"/>

            <!-- Security tip box -->
            <HBox styleClass="security-tip" spacing="10" alignment="CENTER_LEFT">
                <Label text="ℹ" style="-fx-font-size:16px; -fx-text-fill:#0284c7;"/>
                <Label text="Utilisez au moins 6 caractères. Un mot de passe fort combine lettres, chiffres et symboles."
                       styleClass="security-tip-text" wrapText="true"/>
            </HBox>

            <!-- Current password -->
            <VBox styleClass="form-group" spacing="8">
                <Label text="Mot de passe actuel" styleClass="form-field-label"/>
                <PasswordField fx:id="currentPasswordField" styleClass="form-input"
                               promptText="••••••••"/>
                <Label fx:id="currentPasswordError" styleClass="field-error"
                       managed="false" visible="false"/>
            </VBox>

            <!-- New password -->
            <VBox styleClass="form-group" spacing="8">
                <Label text="Nouveau mot de passe" styleClass="form-field-label"/>
                <PasswordField fx:id="newPasswordField" styleClass="form-input"
                               promptText="••••••••"/>
                <Label fx:id="newPasswordError" styleClass="field-error"
                       managed="false" visible="false"/>
            </VBox>

            <!-- Confirm new password -->
            <VBox styleClass="form-group" spacing="8">
                <Label text="Confirmer le nouveau mot de passe" styleClass="form-field-label"/>
                <PasswordField fx:id="confirmPasswordField" styleClass="form-input"
                               promptText="••••••••"/>
                <Label fx:id="confirmPasswordError" styleClass="field-error"
                       managed="false" visible="false"/>
            </VBox>

            <!-- Submit -->
            <Button text="🔒  Mettre à jour le mot de passe"
                    onAction="#handleSave"
                    styleClass="btn-primary-blue" maxWidth="Infinity"/>

            <!-- Back -->
            <Button text="Retour au profil"
                    onAction="#handleCancel"
                    styleClass="btn-outline-modern" maxWidth="Infinity"/>

        </VBox>
    </VBox>
</VBox>