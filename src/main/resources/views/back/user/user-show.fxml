<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controller.back.user.UserShowController"
      styleClass="user-mgmt" spacing="0" alignment="TOP_CENTER">

    <VBox styleClass="detail-card" maxWidth="560" spacing="0">

        <!-- Detail rows -->
        <HBox styleClass="detail-row" spacing="0">
            <Label text="Nom d'utilisateur" styleClass="detail-label" minWidth="150"/>
            <Label fx:id="detailUsername" styleClass="detail-value"/>
        </HBox>
        <HBox styleClass="detail-row" spacing="0">
            <Label text="Email" styleClass="detail-label" minWidth="150"/>
            <Label fx:id="detailEmail" styleClass="detail-value"/>
        </HBox>
        <HBox styleClass="detail-row" spacing="0">
            <Label text="Adresse" styleClass="detail-label" minWidth="150"/>
            <Label fx:id="detailAddress" styleClass="detail-value"/>
        </HBox>
        <HBox styleClass="detail-row" spacing="0">
            <Label text="Téléphone" styleClass="detail-label" minWidth="150"/>
            <Label fx:id="detailTelephone" styleClass="detail-value"/>
        </HBox>
        <HBox styleClass="detail-row" spacing="0" alignment="CENTER_LEFT">
            <Label text="Rôle" styleClass="detail-label" minWidth="150"/>
            <Label fx:id="detailRole" styleClass="detail-value"/>
        </HBox>
        <HBox styleClass="detail-row" spacing="0" alignment="CENTER_LEFT">
            <Label text="Email vérifié" styleClass="detail-label" minWidth="150"/>
            <Label fx:id="detailVerified" styleClass="detail-value"/>
        </HBox>

        <Separator style="-fx-padding: 16 0 16 0;"/>

        <!-- Action buttons -->
        <HBox spacing="12" style="-fx-padding: 20 24 20 24;">
            <Button text="✏  Éditer"    onAction="#handleEdit"   styleClass="btn-add-user"/>
            <Button text="◀  Liste"     onAction="#handleList"   styleClass="btn-outline-modern"/>
            <Button text="🗑  Supprimer" onAction="#handleDelete" styleClass="btn-action-delete-btn"/>
        </HBox>

    </VBox>
</VBox>