<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controller.back.user.UserFormController"
      styleClass="user-mgmt" spacing="0" alignment="TOP_CENTER">

    <VBox styleClass="form-panel" maxWidth="640" spacing="0">

        <!-- Header -->
        <HBox styleClass="user-form-header" spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="formTitleLabel" styleClass="user-form-title"/>
        </HBox>

        <VBox styleClass="form-panel-body" spacing="20">

            <!-- Success / error -->
            <Label fx:id="successLabel" styleClass="alert-success"
                   managed="false" visible="false" wrapText="true"/>
            <Label fx:id="errorLabel" styleClass="auth-alert-error"
                   managed="false" visible="false" wrapText="true"/>

            <!-- Email + Username -->
            <GridPane hgap="16" vgap="0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="0">
                    <Label text="Email" styleClass="form-field-label"/>
                    <TextField fx:id="emailField" styleClass="form-input"
                               promptText="email@exemple.com"/>
                    <Label fx:id="emailError" styleClass="field-error"
                           managed="false" visible="false"/>
                </VBox>
                <VBox spacing="6" GridPane.columnIndex="1">
                    <Label text="Nom d'utilisateur" styleClass="form-field-label"/>
                    <TextField fx:id="usernameField" styleClass="form-input"
                               promptText="Nom d'utilisateur"/>
                    <Label fx:id="usernameError" styleClass="field-error"
                           managed="false" visible="false"/>
                </VBox>
            </GridPane>

            <!-- Password (optional on edit) -->
            <VBox spacing="6">
                <Label fx:id="passwordLabel" text="Mot de passe" styleClass="form-field-label"/>
                <PasswordField fx:id="passwordField" styleClass="form-input"
                               promptText="••••••••"/>
                <Label fx:id="passwordHint" styleClass="field-hint"
                       text="Laisser vide pour conserver le mot de passe actuel"
                       managed="false" visible="false"/>
                <Label fx:id="passwordError" styleClass="field-error"
                       managed="false" visible="false"/>
            </VBox>

            <!-- Address + Telephone -->
            <GridPane hgap="16" vgap="0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="0">
                    <Label text="Adresse" styleClass="form-field-label"/>
                    <TextField fx:id="addressField" styleClass="form-input"
                               promptText="Adresse complète"/>
                </VBox>
                <VBox spacing="6" GridPane.columnIndex="1">
                    <Label text="Téléphone" styleClass="form-field-label"/>
                    <TextField fx:id="telephoneField" styleClass="form-input"
                               promptText="+216 XX XXX XXX"/>
                </VBox>
            </GridPane>

            <!-- Role + Is Verified -->
            <GridPane hgap="16" vgap="0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="0">
                    <Label text="Rôle" styleClass="form-field-label"/>
                    <ComboBox fx:id="roleCombo" styleClass="form-input"
                              maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" alignment="BOTTOM_LEFT" GridPane.columnIndex="1">
                    <CheckBox fx:id="isVerifiedCheck" text="Email vérifié"
                              styleClass="auth-checkbox"/>
                </VBox>
            </GridPane>

            <!-- Action buttons -->
            <HBox spacing="12">
                <Button fx:id="saveButton" text="💾  Enregistrer"
                        onAction="#handleSave"
                        styleClass="btn-add-user"/>
                <Button text="Annuler" onAction="#handleCancel"
                        styleClass="btn-outline-modern"/>
                <Button fx:id="viewButton" text="👁  Voir"
                        onAction="#handleView"
                        styleClass="btn-export"
                        managed="false" visible="false"/>
            </HBox>

        </VBox>
    </VBox>
</VBox>