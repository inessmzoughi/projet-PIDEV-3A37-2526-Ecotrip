<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root-pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controller.back.activity.CategoriesController">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <VBox spacing="24" styleClass="page-body">
                    <padding>
                        <Insets bottom="32" left="32" right="32" top="32"/>
                    </padding>

                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard" styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label text=" > " styleClass="breadcrumb-sep"/>
                            <Button text="Activites" styleClass="breadcrumb-link" onAction="#onNavActivities"/>
                            <Label text=" > " styleClass="breadcrumb-sep"/>
                            <Label text="Categories" styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Categories d'activites" styleClass="page-title"/>
                    </VBox>

                    <HBox spacing="20">
                        <VBox spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="badge, badge-green" text="🏷️"/>
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Total categories"/>
                                    <Label fx:id="statTotal" styleClass="stat-value" text="0"/>
                                    <Label styleClass="stat-sub" text="categories actives"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-blue" text="🏃"/>
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Total activites"/>
                                    <Label fx:id="statActivities" styleClass="stat-value" text="--"/>
                                    <Label styleClass="stat-sub" text="activites enregistrees"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-orange" text="📊"/>
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Moyenne / categorie"/>
                                    <Label fx:id="statAvg" styleClass="stat-value" text="--"/>
                                    <Label styleClass="stat-sub" text="activites par categorie"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <HBox spacing="24">
                        <VBox maxWidth="360" minWidth="360" styleClass="form-card, cat-form-card">
                            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="cat-form-header">
                                <Label fx:id="formPreviewIcon" styleClass="cat-form-preview-icon" text="🏕️"/>
                                <Label fx:id="formTitle" styleClass="cat-form-title" text="Nouvelle Categorie"/>
                            </HBox>

                            <VBox spacing="16" styleClass="form-body">
                                <padding>
                                    <Insets bottom="16" left="22" right="22" top="22"/>
                                </padding>

                                <VBox spacing="5" styleClass="form-group">
                                    <Label styleClass="form-label" text="Nom *"/>
                                    <TextField fx:id="nameField" onKeyReleased="#validateName"
                                               promptText="Ex: Aventure, Nature..." styleClass="form-input"/>
                                    <Label fx:id="errName" managed="false" styleClass="err-msg"
                                           text="Le nom est requis (min 3 caracteres)." visible="false"/>
                                </VBox>

                                <VBox spacing="8" styleClass="form-group">
                                    <HBox styleClass="ai-assist-box" alignment="CENTER_LEFT" spacing="12">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label text="✨ Assistant description" styleClass="ai-assist-title"/>
                                            <Label text="Complete la categorie avec un texte coherent et vendeur."
                                                   styleClass="ai-assist-subtitle" wrapText="true"/>
                                        </VBox>
                                        <Button fx:id="generateDescBtn" text="✨ Generer"
                                                styleClass="ai-assist-btn" onAction="#onGenerateDescription"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <ProgressIndicator fx:id="aiProgress" progress="-1.0"
                                                           maxHeight="20" maxWidth="20" visible="false"/>
                                        <Label fx:id="aiStatusLabel" visible="false" managed="false"
                                               styleClass="ai-assist-status"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="5" styleClass="form-group">
                                    <Label styleClass="form-label" text="Description"/>
                                    <TextArea fx:id="descriptionField" prefHeight="80"
                                              promptText="Decrivez la categorie..."
                                              styleClass="form-textarea" wrapText="true"
                                              onKeyReleased="#updateCounter"/>
                                    <Label fx:id="charCount" text="0 / 1000 caracteres" styleClass="char-count"/>
                                </VBox>

                                <VBox spacing="6" styleClass="form-group">
                                    <Label styleClass="form-label" text="Icone"/>
                                    <FlowPane fx:id="iconGrid" hgap="6" vgap="6"
                                              styleClass="icon-picker-pane"/>
                                </VBox>

                                <VBox spacing="6" styleClass="form-group">
                                    <Label styleClass="form-label" text="Couleur"/>
                                    <FlowPane fx:id="colorGrid" hgap="6" vgap="6"
                                              styleClass="color-picker-pane"/>
                                </VBox>
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                                <Button onAction="#onReset" styleClass="btn-cancel" text="Reinitialiser"/>
                                <Button fx:id="submitBtn" onAction="#onSubmit" styleClass="btn-submit" text="Enregistrer"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                                    <Label styleClass="table-card-title" text="Toutes les categories"/>
                                    <Label fx:id="badgeCount" styleClass="badge, badge-green" text="0"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="6" styleClass="search-wrap">
                                    <Label styleClass="search-icon" text="Rech"/>
                                    <TextField fx:id="searchField" onKeyReleased="#onSearch"
                                               prefWidth="200" promptText="Rechercher..."
                                               styleClass="search-input"/>
                                </HBox>
                            </HBox>

                            <FlowPane fx:id="catCardsPane" hgap="16" prefWrapLength="600"
                                      styleClass="cat-cards-flow" vgap="16"/>

                            <VBox fx:id="emptyState" alignment="CENTER" managed="false"
                                  spacing="8" styleClass="empty-state" visible="false">
                                <Label styleClass="empty-label" text="Aucune categorie trouvee."/>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
