<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.back.activity.CategoriesController"
            styleClass="root-pane"
            stylesheets="@../../../styles/ecotrip.css">
    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="24">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <!-- Breadcrumb -->
                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard" styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Button text="Activités" styleClass="breadcrumb-link" onAction="#onNavActivities"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Label text="Catégories" styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Catégories d'Activités" styleClass="page-title"/>
                    </VBox>

                    <!-- Stats -->
                    <HBox spacing="20">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🏷️" styleClass="stat-icon stat-icon-green"/>
                                <VBox spacing="2">
                                    <Label text="Total Catégories" styleClass="stat-label"/>
                                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                                    <Label text="catégories actives" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🏃" styleClass="stat-icon stat-icon-blue"/>
                                <VBox spacing="2">
                                    <Label text="Total Activités" styleClass="stat-label"/>
                                    <Label fx:id="statActivities" text="—" styleClass="stat-value"/>
                                    <Label text="activités enregistrées" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="📊" styleClass="stat-icon stat-icon-orange"/>
                                <VBox spacing="2">
                                    <Label text="Moyenne / Catégorie" styleClass="stat-label"/>
                                    <Label fx:id="statAvg" text="—" styleClass="stat-value"/>
                                    <Label text="activités par catégorie" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <HBox alignment="TOP_LEFT" spacing="24">

                        <!-- FORM -->
                        <VBox minWidth="340" maxWidth="340" spacing="0" styleClass="form-card">
                            <HBox styleClass="form-card-header" alignment="CENTER_LEFT" spacing="14">
                                <Label fx:id="formIcon" text="🏷️" styleClass="form-icon"/>
                                <VBox spacing="4">
                                    <Label fx:id="formTitle" text="Nouvelle Catégorie" styleClass="form-heading-title"/>
                                    <Label fx:id="formSubtitle" text="Remplissez les informations." styleClass="form-heading-sub"/>
                                </VBox>
                            </HBox>
                            <VBox styleClass="form-body" spacing="14">
                                <padding><Insets top="20" right="20" bottom="16" left="20"/></padding>

                                <!-- Name -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="🏷️ Nom *" styleClass="form-label"/>
                                    <TextField fx:id="nameField" promptText="Ex: Aventure, Nature…"
                                               styleClass="form-input" onKeyReleased="#validateName"/>
                                    <Label fx:id="errName" text="Le nom est requis (min 3 caractères)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <!-- Icon Picker -->
                                <VBox spacing="8" styleClass="form-group">
                                    <Label text="🎨 Icône" styleClass="form-label"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Button fx:id="iconPickerBtn" text="🏷️"
                                                styleClass="icon-picker-btn"
                                                onAction="#toggleIconPicker"/>
                                        <TextField fx:id="iconField" promptText="ou saisir un emoji"
                                                   styleClass="form-input" prefWidth="180"/>
                                    </HBox>
                                    <!-- Icon picker grid -->
                                    <VBox fx:id="iconPickerBox" visible="false" managed="false"
                                          styleClass="table-card" spacing="0">
                                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                                        <FlowPane fx:id="iconOptionsPane" hgap="6" vgap="6"/>
                                    </VBox>
                                </VBox>

                                <!-- Description -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="📝 Description" styleClass="form-label"/>
                                    <TextArea fx:id="descriptionField" promptText="Décrivez la catégorie…"
                                              styleClass="form-textarea" prefHeight="100"
                                              wrapText="true" onKeyReleased="#updateCounter"/>
                                    <Label fx:id="charCount" text="0 / 1000 caractères" styleClass="char-count"/>
                                </VBox>
                            </VBox>
                            <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
                                <Button text="↺ Réinitialiser" styleClass="btn-cancel" onAction="#onReset"/>
                                <Button fx:id="submitBtn" text="➕ Ajouter" styleClass="btn-submit" onAction="#onSubmit"/>
                            </HBox>
                        </VBox>

                        <!-- TABLE -->
                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="🏷️ Toutes les catégories" styleClass="table-card-title"/>
                                    <Label fx:id="badgeCount" text="0" styleClass="badge badge-green"/>
                                </HBox>
                                <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                                    <Label text="🔍" styleClass="search-icon"/>
                                    <TextField fx:id="searchField" promptText="Rechercher…"
                                               styleClass="search-input" onKeyReleased="#onSearch" prefWidth="200"/>
                                </HBox>
                            </HBox>

                            <VBox styleClass="table-card" spacing="0" VBox.vgrow="ALWAYS">
                                <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colIndex" text="#"            prefWidth="45"/>
                                        <TableColumn fx:id="colIcon"  text="Icône"        prefWidth="80"/>
                                        <TableColumn fx:id="colName"  text="Nom"          prefWidth="180"/>
                                        <TableColumn fx:id="colDesc"  text="Description"  prefWidth="260"/>
                                        <TableColumn fx:id="colActions" text="Actions"    prefWidth="160"/>
                                    </columns>
                                    <placeholder>
                                        <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                            <Label text="🏷️" styleClass="empty-icon"/>
                                            <Label text="Aucune catégorie trouvée." styleClass="empty-label"/>
                                        </VBox>
                                    </placeholder>
                                </TableView>
                                <HBox styleClass="pagination-bar" alignment="CENTER_LEFT" spacing="8">
                                    <Label fx:id="pagInfo" text="" styleClass="pag-info" HBox.hgrow="ALWAYS"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <HBox fx:id="pagButtons" spacing="4"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>