<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controller.back.activity.ListActivitiesController"
            styleClass="root-pane">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="24">
                    <padding>
                        <Insets top="32" right="32" bottom="32" left="32"/>
                    </padding>

                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard" styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label text=" > " styleClass="breadcrumb-sep"/>
                            <Label text="Activites" styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Gestion des Activites" styleClass="page-title"/>
                    </VBox>

                    <HBox spacing="20">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🏃" styleClass="stat-icon, stat-icon-green"/>
                                <VBox spacing="2">
                                    <Label text="Total Activites" styleClass="stat-label"/>
                                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                                    <Label text="activites enregistrees" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="✅" styleClass="stat-icon, stat-icon-blue"/>
                                <VBox spacing="2">
                                    <Label text="Activites actives" styleClass="stat-label"/>
                                    <Label fx:id="statActive" text="0" styleClass="stat-value"/>
                                    <Label text="en ligne" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="💰" styleClass="stat-icon, stat-icon-orange"/>
                                <VBox spacing="2">
                                    <Label text="Prix moyen" styleClass="stat-label"/>
                                    <Label fx:id="statAvgPrice" text="--" styleClass="stat-value"/>
                                    <Label text="par activite" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <HBox spacing="24">
                        <VBox minWidth="380" maxWidth="380" styleClass="form-card">
                            <HBox styleClass="form-card-header" alignment="CENTER_LEFT" spacing="14">
                                <Label fx:id="formIcon" text="🏃" styleClass="form-icon"/>
                                <VBox spacing="4">
                                    <Label fx:id="formTitle" text="Nouvelle Activite" styleClass="form-heading-title"/>
                                    <Label fx:id="formSubtitle" text="Remplissez les informations." styleClass="form-heading-sub"/>
                                </VBox>
                            </HBox>

                            <VBox styleClass="form-body" spacing="14">
                                <padding>
                                    <Insets top="20" right="20" bottom="16" left="20"/>
                                </padding>

                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="Titre *" styleClass="form-label"/>
                                    <TextField fx:id="titleField" promptText="Ex: Randonnee Jebel Zaghouan"
                                               styleClass="form-input" onKeyReleased="#validateTitle"/>
                                    <Label fx:id="errTitle" text="Titre requis (3-150 car.)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <HBox spacing="12">
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Categorie *" styleClass="form-label"/>
                                        <ComboBox fx:id="categoryCombo" promptText="Choisir..."
                                                  styleClass="sort-select" maxWidth="Infinity"/>
                                        <Label fx:id="errCategory" text="Categorie requise."
                                               styleClass="err-msg" managed="false" visible="false"/>
                                    </VBox>
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Statut" styleClass="form-label"/>
                                        <ComboBox fx:id="activeCombo" styleClass="sort-select" maxWidth="Infinity"/>
                                    </VBox>
                                </HBox>

                                <HBox spacing="12">
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Prix (TND) *" styleClass="form-label"/>
                                        <TextField fx:id="priceField" promptText="Ex: 50.0"
                                                   styleClass="form-input" onKeyReleased="#validatePrice"/>
                                        <Label fx:id="errPrice" text="Prix positif requis."
                                               styleClass="err-msg" managed="false" visible="false"/>
                                    </VBox>
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Duree (min) *" styleClass="form-label"/>
                                        <TextField fx:id="durationField" promptText="Ex: 120"
                                                   styleClass="form-input" onKeyReleased="#validateDuration"/>
                                        <Label fx:id="errDuration" text="Duree entre 5 et 1440."
                                               styleClass="err-msg" managed="false" visible="false"/>
                                    </VBox>
                                </HBox>

                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="Lieu *" styleClass="form-label"/>
                                    <TextField fx:id="locationField" promptText="Ex: Zaghouan, Tunisie"
                                               styleClass="form-input" onKeyReleased="#validateLocation"/>
                                    <Label fx:id="errLocation" text="Lieu requis (min 3 car.)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <HBox spacing="12">
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Max participants" styleClass="form-label"/>
                                        <TextField fx:id="maxParticipantsField" promptText="Ex: 20"
                                                   styleClass="form-input"/>
                                    </VBox>
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Guide" styleClass="form-label"/>
                                        <ComboBox fx:id="guideCombo" promptText="-- Aucun --"
                                                  styleClass="sort-select" maxWidth="Infinity"/>
                                    </VBox>
                                </HBox>

                                <VBox spacing="8" styleClass="form-group">
                                    <Label text="Photo de l'activite" styleClass="form-label"/>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <ImageView fx:id="photoPreview" fitWidth="60" fitHeight="60"
                                                   preserveRatio="true" styleClass="photo-preview"/>
                                        <VBox spacing="6">
                                            <Button text="Choisir une photo" styleClass="photo-upload-btn"
                                                    onAction="#onChoosePhoto"/>
                                            <Label fx:id="photoLabel" text="Aucune photo selectionnee"
                                                   styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <TextField fx:id="imageField" promptText="Ou coller une URL"
                                               styleClass="form-input"/>
                                </VBox>

                                <HBox spacing="12">
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Latitude" styleClass="form-label"/>
                                        <TextField fx:id="latitudeField" promptText="Ex: 36.8065"
                                                   styleClass="form-input"/>
                                    </VBox>
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="Longitude" styleClass="form-label"/>
                                        <TextField fx:id="longitudeField" promptText="Ex: 10.1815"
                                                   styleClass="form-input"/>
                                    </VBox>
                                </HBox>

                                <VBox spacing="8" styleClass="form-group">
                                    <VBox styleClass="map-preview-card" spacing="10">
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                                <Label text="Apercu carte" styleClass="map-preview-title"/>
                                                <Label text="Visualisez la position exacte de l'activite pendant la saisie."
                                                       styleClass="map-preview-subtitle" wrapText="true"/>
                                            </VBox>
                                            <Button fx:id="openMapBtn" text="Ouvrir"
                                                    styleClass="map-preview-btn" onAction="#onOpenMap"/>
                                        </HBox>
                                        <WebView fx:id="mapPreview" prefHeight="190" minHeight="190"
                                                 styleClass="map-preview-webview"/>
                                        <Label fx:id="mapStatusLabel" styleClass="map-status-label"/>
                                    </VBox>
                                </VBox>

                                <VBox spacing="8" styleClass="form-group">
                                    <HBox styleClass="ai-assist-box" alignment="CENTER_LEFT" spacing="12">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label text="✨ Assistant description" styleClass="ai-assist-title"/>
                                            <Label text="Genere une description dans le meme ton que votre interface."
                                                   styleClass="ai-assist-subtitle" wrapText="true"/>
                                        </VBox>
                                        <Button fx:id="generateDescBtn" text="✨ Generer"
                                                styleClass="ai-assist-btn" onAction="#onGenerateDescription"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <ProgressIndicator fx:id="aiProgress" progress="-1.0"
                                                           maxHeight="20" maxWidth="20" visible="false"/>
                                        <Label fx:id="aiStatusLabel" visible="false" managed="false"
                                               styleClass="ai-assist-status"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="Description *" styleClass="form-label"/>
                                    <TextArea fx:id="descriptionField" promptText="Decrivez l'activite..."
                                              styleClass="form-textarea" prefHeight="90"
                                              wrapText="true" onKeyReleased="#updateCounter"/>
                                    <Label fx:id="charCount" text="0 / 5000 caracteres" styleClass="char-count"/>
                                    <Label fx:id="errDescription" text="Description requise (min 10 car.)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>
                            </VBox>

                            <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
                                <Button text="Reinitialiser" styleClass="btn-cancel" onAction="#onReset"/>
                                <Button fx:id="submitBtn" text="Ajouter" styleClass="btn-submit" onAction="#onSubmit"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Toutes les activites" styleClass="table-card-title"/>
                                    <Label fx:id="badgeCount" text="0" styleClass="badge, badge-green"/>
                                </HBox>
                                <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                                    <Label text="Rech" styleClass="search-icon"/>
                                    <TextField fx:id="searchField" promptText="Rechercher..."
                                               styleClass="search-input" onKeyReleased="#onSearch" prefWidth="200"/>
                                </HBox>
                                <ComboBox fx:id="sortCombo" promptText="Trier par..."
                                          styleClass="sort-select" onAction="#onSort" prefWidth="160"/>
                            </HBox>

                            <VBox styleClass="table-card">
                                <TableView fx:id="tableView" styleClass="main-table"
                                           prefHeight="420" maxHeight="420">
                                    <columns>
                                        <TableColumn fx:id="colIndex" text="#" minWidth="40"/>
                                        <TableColumn fx:id="colTitle" text="Titre" minWidth="130"/>
                                        <TableColumn fx:id="colCategory" text="Categorie" minWidth="100"/>
                                        <TableColumn fx:id="colPrice" text="Prix" minWidth="80"/>
                                        <TableColumn fx:id="colDuration" text="Duree" minWidth="80"/>
                                        <TableColumn fx:id="colLocation" text="Lieu" minWidth="100"/>
                                        <TableColumn fx:id="colActive" text="Statut" minWidth="80"/>
                                        <TableColumn fx:id="colActions" text="Actions" minWidth="120"/>
                                    </columns>
                                    <placeholder>
                                        <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                            <Label text="Aucune activite trouvee." styleClass="empty-label"/>
                                        </VBox>
                                    </placeholder>
                                </TableView>
                                <HBox fx:id="paginationBar" styleClass="pagination-bar"
                                      alignment="CENTER_LEFT" spacing="8">
                                    <Label fx:id="pagInfo" styleClass="pag-info" HBox.hgrow="ALWAYS"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <HBox fx:id="pagButtons" spacing="4"/>
                                </HBox>
                            </VBox>

                            <HBox spacing="12">
                                <Button text="Gerer les categories" styleClass="btn-back"
                                        onAction="#onNavCategories" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button text="Gerer les guides" styleClass="btn-back"
                                        onAction="#onNavGuides" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button text="Gerer les plannings" styleClass="btn-back"
                                        onAction="#onNavSchedules" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
