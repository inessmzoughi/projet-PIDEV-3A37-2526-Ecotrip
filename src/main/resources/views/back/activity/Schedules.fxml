<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controller.back.activity.SchedulesController"
            styleClass="root-pane"
            stylesheets="@../../../styles/ecotrip.css">
    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="24">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <!-- Breadcrumb + Title -->
                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard" styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Button text="Activités" styleClass="breadcrumb-link" onAction="#onNavActivities"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Label text="Plannings" styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Gestion des Plannings" styleClass="page-title"/>
                    </VBox>

                    <!-- Stat Cards -->
                    <HBox spacing="20">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="📅" styleClass="stat-icon stat-icon-green"/>
                                <VBox spacing="2">
                                    <Label text="Total Plannings" styleClass="stat-label"/>
                                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                                    <Label text="plannings enregistrés" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🎯" styleClass="stat-icon stat-icon-blue"/>
                                <VBox spacing="2">
                                    <Label text="Places Disponibles" styleClass="stat-label"/>
                                    <Label fx:id="statSpots" text="0" styleClass="stat-value"/>
                                    <Label text="places au total" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🏃" styleClass="stat-icon stat-icon-orange"/>
                                <VBox spacing="2">
                                    <Label text="Activités Planifiées" styleClass="stat-label"/>
                                    <Label fx:id="statActivities" text="0" styleClass="stat-value"/>
                                    <Label text="activités distinctes" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <HBox alignment="TOP_LEFT" spacing="24">

                        <!-- FORM -->
                        <VBox minWidth="360" maxWidth="360" spacing="0" styleClass="form-card">
                            <HBox styleClass="form-card-header" alignment="CENTER_LEFT" spacing="14">
                                <Label fx:id="formIcon" text="📅" styleClass="form-icon"/>
                                <VBox spacing="4">
                                    <Label fx:id="formTitle" text="Nouveau Planning" styleClass="form-heading-title"/>
                                    <Label fx:id="formSubtitle" text="Remplissez les informations." styleClass="form-heading-sub"/>
                                </VBox>
                            </HBox>
                            <VBox styleClass="form-body" spacing="14">
                                <padding><Insets top="20" right="20" bottom="16" left="20"/></padding>

                                <!-- Activity -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="🏃 Activité *" styleClass="form-label"/>
                                    <ComboBox fx:id="activityCombo" promptText="Choisir une activité…"
                                              styleClass="sort-select" maxWidth="Infinity"/>
                                    <Label fx:id="errActivity" text="Activité requise."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <!-- Start date -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="📅 Date de début *" styleClass="form-label"/>
                                    <TextField fx:id="startAtField" promptText="Ex: 2025-06-15 09:00"
                                               styleClass="form-input" onKeyReleased="#validateStartAt"/>
                                    <Label fx:id="errStartAt" text="Format: yyyy-MM-dd HH:mm (date future)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <!-- End date -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="📅 Date de fin *" styleClass="form-label"/>
                                    <TextField fx:id="endAtField" promptText="Ex: 2025-06-15 17:00"
                                               styleClass="form-input" onKeyReleased="#validateEndAt"/>
                                    <Label fx:id="errEndAt" text="Format: yyyy-MM-dd HH:mm (après début)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <!-- Available spots -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="🎯 Places disponibles *" styleClass="form-label"/>
                                    <TextField fx:id="spotsField" promptText="Ex: 15"
                                               styleClass="form-input" onKeyReleased="#validateSpots"/>
                                    <Label fx:id="errSpots" text="Places disponibles (min 1)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                            </VBox>
                            <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
                                <Button text="↺ Réinitialiser" styleClass="btn-cancel" onAction="#onReset"/>
                                <Button fx:id="submitBtn" text="➕ Ajouter" styleClass="btn-submit" onAction="#onSubmit"/>
                            </HBox>
                        </VBox>

                        <!-- TABLE -->
                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="📅 Tous les plannings" styleClass="table-card-title"/>
                                    <Label fx:id="badgeCount" text="0" styleClass="badge badge-green"/>
                                </HBox>
                                <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                                    <Label text="🔍" styleClass="search-icon"/>
                                    <TextField fx:id="searchField" promptText="Rechercher activité…"
                                               styleClass="search-input" onKeyReleased="#onSearch" prefWidth="200"/>
                                </HBox>
                            </HBox>

                            <VBox styleClass="table-card" spacing="0" VBox.vgrow="ALWAYS">
                                <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colIndex"    text="#"           prefWidth="45"/>
                                        <TableColumn fx:id="colActivity" text="Activité"    prefWidth="160"/>
                                        <TableColumn fx:id="colStart"    text="Début"       prefWidth="140"/>
                                        <TableColumn fx:id="colEnd"      text="Fin"         prefWidth="140"/>
                                        <TableColumn fx:id="colSpots"    text="Places"      prefWidth="70"/>
                                        <TableColumn fx:id="colActions"  text="Actions"     prefWidth="160"/>
                                    </columns>
                                    <placeholder>
                                        <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                            <Label text="📅" styleClass="empty-icon"/>
                                            <Label text="Aucun planning trouvé." styleClass="empty-label"/>
                                        </VBox>
                                    </placeholder>
                                </TableView>
                                <HBox styleClass="pagination-bar" alignment="CENTER_LEFT" spacing="8">
                                    <Label fx:id="pagInfo" text="" styleClass="pag-info" HBox.hgrow="ALWAYS"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <HBox fx:id="pagButtons" spacing="4"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>