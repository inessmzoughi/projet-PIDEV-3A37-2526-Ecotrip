<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.back.activity.GuidesController"
            styleClass="root-pane"
            stylesheets="@../../../styles/ecotrip.css">
    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="24">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <!-- Breadcrumb + Title -->
                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard" styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Button text="Activités" styleClass="breadcrumb-link" onAction="#onNavActivities"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Label text="Guides" styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Gestion des Guides" styleClass="page-title"/>
                    </VBox>

                    <!-- Stat Cards -->
                    <HBox spacing="20">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🧭" styleClass="stat-icon stat-icon-green"/>
                                <VBox spacing="2">
                                    <Label text="Total Guides" styleClass="stat-label"/>
                                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                                    <Label text="guides enregistrés" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="⭐" styleClass="stat-icon stat-icon-blue"/>
                                <VBox spacing="2">
                                    <Label text="Note Moyenne" styleClass="stat-label"/>
                                    <Label fx:id="statRating" text="—" styleClass="stat-value"/>
                                    <Label text="sur 5" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🏃" styleClass="stat-icon stat-icon-orange"/>
                                <VBox spacing="2">
                                    <Label text="Activités Assignées" styleClass="stat-label"/>
                                    <Label fx:id="statAssigned" text="—" styleClass="stat-value"/>
                                    <Label text="activités avec guide" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <HBox alignment="TOP_LEFT" spacing="24">

                        <!-- FORM -->
                        <VBox minWidth="360" maxWidth="360" spacing="0" styleClass="form-card">
                            <HBox styleClass="form-card-header" alignment="CENTER_LEFT" spacing="14">
                                <Label fx:id="formIcon" text="🧭" styleClass="form-icon"/>
                                <VBox spacing="4">
                                    <Label fx:id="formTitle" text="Nouveau Guide" styleClass="form-heading-title"/>
                                    <Label fx:id="formSubtitle" text="Remplissez les informations." styleClass="form-heading-sub"/>
                                </VBox>
                            </HBox>
                            <VBox styleClass="form-body" spacing="14">
                                <padding><Insets top="20" right="20" bottom="16" left="20"/></padding>

                                <!-- First + Last name -->
                                <HBox spacing="12">
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="👤 Prénom *" styleClass="form-label"/>
                                        <TextField fx:id="firstNameField" promptText="Ex: Ahmed"
                                                   styleClass="form-input" onKeyReleased="#validateFirstName"/>
                                        <Label fx:id="errFirstName" text="Prénom requis (min 2 car.)."
                                               styleClass="err-msg" managed="false" visible="false"/>
                                    </VBox>
                                    <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                        <Label text="👤 Nom *" styleClass="form-label"/>
                                        <TextField fx:id="lastNameField" promptText="Ex: Ben Ali"
                                                   styleClass="form-input" onKeyReleased="#validateLastName"/>
                                        <Label fx:id="errLastName" text="Nom requis (min 2 car.)."
                                               styleClass="err-msg" managed="false" visible="false"/>
                                    </VBox>
                                </HBox>

                                <!-- Email -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="📧 Email *" styleClass="form-label"/>
                                    <TextField fx:id="emailField" promptText="Ex: guide@ecotrip.tn"
                                               styleClass="form-input" onKeyReleased="#validateEmail"/>
                                    <Label fx:id="errEmail" text="Email invalide."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <!-- Phone -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="📞 Téléphone *" styleClass="form-label"/>
                                    <TextField fx:id="phoneField" promptText="Ex: +216 98 123 456"
                                               styleClass="form-input" onKeyReleased="#validatePhone"/>
                                    <Label fx:id="errPhone" text="Téléphone requis (min 10 car.)."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <!-- Rating -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="⭐ Note (0-5)" styleClass="form-label"/>
                                    <TextField fx:id="ratingField" promptText="Ex: 4.5"
                                               styleClass="form-input" onKeyReleased="#validateRating"/>
                                    <Label fx:id="errRating" text="Note entre 0 et 5."
                                           styleClass="err-msg" managed="false" visible="false"/>
                                </VBox>

                                <!-- Bio -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="📝 Biographie" styleClass="form-label"/>
                                    <TextArea fx:id="bioField" promptText="Décrivez le guide…"
                                              styleClass="form-textarea" prefHeight="80"
                                              wrapText="true" onKeyReleased="#updateCounter"/>
                                    <Label fx:id="charCount" text="0 / 5000 caractères" styleClass="char-count"/>
                                </VBox>

                                <!-- Photo -->
                                <VBox spacing="5" styleClass="form-group">
                                    <Label text="🖼️ Photo (URL)" styleClass="form-label"/>
                                    <TextField fx:id="photoField" promptText="Ex: https://…"
                                               styleClass="form-input"/>
                                </VBox>

                            </VBox>
                            <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
                                <Button text="↺ Réinitialiser" styleClass="btn-cancel" onAction="#onReset"/>
                                <Button fx:id="submitBtn" text="➕ Ajouter" styleClass="btn-submit" onAction="#onSubmit"/>
                            </HBox>
                        </VBox>

                        <!-- TABLE -->
                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="🧭 Tous les guides" styleClass="table-card-title"/>
                                    <Label fx:id="badgeCount" text="0" styleClass="badge badge-green"/>
                                </HBox>
                                <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                                    <Label text="🔍" styleClass="search-icon"/>
                                    <TextField fx:id="searchField" promptText="Rechercher…"
                                               styleClass="search-input" onKeyReleased="#onSearch" prefWidth="200"/>
                                </HBox>
                            </HBox>

                            <VBox styleClass="table-card" spacing="0" VBox.vgrow="ALWAYS">
                                <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colIndex"  text="#"           prefWidth="45"/>
                                        <TableColumn fx:id="colName"   text="Nom complet" prefWidth="160"/>
                                        <TableColumn fx:id="colEmail"  text="Email"       prefWidth="180"/>
                                        <TableColumn fx:id="colPhone"  text="Téléphone"   prefWidth="120"/>
                                        <TableColumn fx:id="colRating" text="Note"        prefWidth="70"/>
                                        <TableColumn fx:id="colActions" text="Actions"    prefWidth="160"/>
                                    </columns>
                                    <placeholder>
                                        <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                            <Label text="🧭" styleClass="empty-icon"/>
                                            <Label text="Aucun guide trouvé." styleClass="empty-label"/>
                                        </VBox>
                                    </placeholder>
                                </TableView>
                                <HBox styleClass="pagination-bar" alignment="CENTER_LEFT" spacing="8">
                                    <Label fx:id="pagInfo" text="" styleClass="pag-info" HBox.hgrow="ALWAYS"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <HBox fx:id="pagButtons" spacing="4"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>