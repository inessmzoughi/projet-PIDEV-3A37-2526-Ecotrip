    <center>
        <VBox styleClass="main-content">
           <!-- <HBox styleClass="topbar" alignment="CENTER_LEFT">
                <Label text="Ajouter un Hébergement" styleClass="topbar-title" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
