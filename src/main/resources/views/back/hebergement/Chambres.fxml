<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controller.back.hebergement.ChambresController"
            styleClass="root-pane">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="20">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard"    styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label  text=" › "          styleClass="breadcrumb-sep"/>
                            <Button text="Hébergements" styleClass="breadcrumb-link" onAction="#onNavHebergements"/>
                            <Label  text=" › "          styleClass="breadcrumb-sep"/>
                            <Label  text="Chambres"     styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Gestion des Chambres" styleClass="page-title"/>
                    </VBox>

                    <HBox spacing="16">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🛏️" styleClass="stat-icon, stat-icon-green"/>
                                <VBox spacing="2">
                                    <Label text="Total Chambres" styleClass="stat-label"/>
                                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                                    <Label text="enregistrées"   styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="💰" styleClass="stat-icon, stat-icon-blue"/>
                                <VBox spacing="2">
                                    <Label text="Prix Moyen"  styleClass="stat-label"/>
                                    <Label fx:id="statPrix" text="—" styleClass="stat-value"/>
                                    <Label text="DT / nuit"  styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="👤" styleClass="stat-icon, stat-icon-purple"/>
                                <VBox spacing="2">
                                    <Label text="Capacité Moy."  styleClass="stat-label"/>
                                    <Label fx:id="statCap" text="—" styleClass="stat-value"/>
                                    <Label text="pers. / chambre" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🏨" styleClass="stat-icon, stat-icon-orange"/>
                                <VBox spacing="2">
                                    <Label text="Hébergements"  styleClass="stat-label"/>
                                    <Label fx:id="statHeb" text="0" styleClass="stat-value"/>
                                    <Label text="avec chambres"  styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- FORM PANEL -->
                    <VBox fx:id="formPanel" styleClass="form-card, inline-form-panel"
                          visible="false" managed="false" spacing="0">
                        <HBox styleClass="cat-form-header" alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="formPanelTitle" text="🛏️ Nouvelle Chambre"
                                   styleClass="cat-form-title" HBox.hgrow="ALWAYS"/>
                            <Button text="✕" styleClass="fp-close-btn" onAction="#onCloseForm"/>
                        </HBox>
                        <VBox styleClass="form-body" spacing="16">
                            <padding><Insets top="20" right="24" bottom="12" left="24"/></padding>
                            <HBox spacing="16">
                                <VBox HBox.hgrow="ALWAYS" spacing="5" styleClass="form-group">
                                    <Label text="Numéro de chambre *" styleClass="form-label"/>
                                    <TextField fx:id="numeroField" promptText="Ex: 101"
                                               styleClass="form-input" onKeyReleased="#validateNumero"/>
                                    <Label fx:id="errNumero" styleClass="err-msg" visible="false" managed="false"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" spacing="5" styleClass="form-group">
                                    <Label text="Hébergement *" styleClass="form-label"/>
                                    <ComboBox fx:id="hebCombo" promptText="-- Sélectionner --"
                                              styleClass="sort-select" maxWidth="Infinity"/>
                                    <Label fx:id="errHeb" styleClass="err-msg" visible="false" managed="false"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="16">
                                <VBox HBox.hgrow="ALWAYS" spacing="5" styleClass="form-group">
                                    <Label text="Type *" styleClass="form-label"/>
                                    <ComboBox fx:id="typeCombo" styleClass="sort-select" maxWidth="Infinity"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" spacing="5" styleClass="form-group">
                                    <Label text="Prix / nuit (DT) *" styleClass="form-label"/>
                                    <TextField fx:id="prixField" promptText="Ex: 120"
                                               styleClass="form-input" onKeyReleased="#validatePrix"/>
                                    <Label fx:id="errPrix" styleClass="err-msg" visible="false" managed="false"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" spacing="5" styleClass="form-group">
                                    <Label text="Capacité (1-4) *" styleClass="form-label"/>
                                    <TextField fx:id="capField" promptText="Ex: 2"
                                               styleClass="form-input" onKeyReleased="#validateCap"/>
                                    <Label fx:id="errCap" styleClass="err-msg" visible="false" managed="false"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="16">
                                <VBox HBox.hgrow="ALWAYS" spacing="5" styleClass="form-group">
                                    <Label text="Disponibilité" styleClass="form-label"/>
                                    <ComboBox fx:id="dispoCombo" styleClass="sort-select" maxWidth="Infinity"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" spacing="5" styleClass="form-group">
                                    <Label text="Description" styleClass="form-label"/>
                                    <TextArea fx:id="descField" promptText="Description de la chambre…"
                                              styleClass="form-input" prefRowCount="3"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
                            <Button text="Annuler"        styleClass="btn-cancel" onAction="#onCloseForm"/>
                            <Button text="💾 Enregistrer" styleClass="btn-submit" onAction="#onSave"/>
                        </HBox>
                    </VBox>

                    <!-- Action Bar -->
                    <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                        <Button text="＋ Ajouter une chambre" styleClass="btn-primary" onAction="#onOpenForm"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                            <Label text="🔍" styleClass="search-icon"/>
                            <TextField fx:id="searchField" promptText="Rechercher…"
                                       styleClass="search-input" prefWidth="220" onKeyReleased="#onSearch"/>
                        </HBox>
                        <ComboBox fx:id="filterType" promptText="Tous les types"
                                  styleClass="sort-select" prefWidth="150" onAction="#onSearch"/>
                        <ComboBox fx:id="sortCombo"  promptText="Trier par…"
                                  styleClass="sort-select" prefWidth="160" onAction="#onSearch"/>
                    </HBox>

                    <!-- Table Card -->
                    <VBox styleClass="table-card" spacing="0">
                        <HBox styleClass="table-card-header" alignment="CENTER_LEFT" spacing="8">
                            <Label text="🛏️ Liste des Chambres" styleClass="table-card-title" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="badgeCount" text="0" styleClass="badge, badge-green"/>
                        </HBox>
                        <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNumero"  text="Numéro"       prefWidth="120"/>
                                <TableColumn fx:id="colHeb"     text="Hébergement"  prefWidth="170"/>
                                <TableColumn fx:id="colType"    text="Type"         prefWidth="110"/>
                                <TableColumn fx:id="colPrix"    text="Prix / nuit"  prefWidth="110"/>
                                <TableColumn fx:id="colCap"     text="Capacité"     prefWidth="90"/>
                                <TableColumn fx:id="colDispo"   text="Disponible"   prefWidth="130"/>
                                <TableColumn fx:id="colDesc"    text="Description"  prefWidth="170"/>
                                <TableColumn fx:id="colActions" text="Actions"      prefWidth="180"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                    <Label text="🔍" styleClass="empty-icon"/>
                                    <Label text="Aucune chambre trouvée." styleClass="empty-label"/>
                                </VBox>
                            </placeholder>
                        </TableView>

                        <!-- Pagination — même design que ListHebergements -->
                        <HBox fx:id="paginationBar" styleClass="pagination-bar"
                              alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="pagInfo" styleClass="pag-info" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox fx:id="pagButtons" spacing="4"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
