<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controller.back.hebergement.ChambresController">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <VBox spacing="20" styleClass="page-body">
                    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button onAction="#onNavDashboard" styleClass="breadcrumb-link" text="Dashboard" />
                            <Label styleClass="breadcrumb-sep" text=" › " />
                            <Button onAction="#onNavHebergements" styleClass="breadcrumb-link" text="Hébergements" />
                            <Label styleClass="breadcrumb-sep" text=" › " />
                            <Label styleClass="breadcrumb-active" text="Chambres" />
                        </HBox>
                        <Label styleClass="page-title" text="Gestion des Chambres" />
                    </VBox>

                    <HBox spacing="16">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-green" text="🛏️" />
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Total Chambres" />
                                    <Label fx:id="statTotal" styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-sub" text="enregistrées" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-blue" text="💰" />
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Prix Moyen" />
                                    <Label fx:id="statPrix" styleClass="stat-value" text="—" />
                                    <Label styleClass="stat-sub" text="DT / nuit" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-purple" text="👤" />
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Capacité Moy." />
                                    <Label fx:id="statCap" styleClass="stat-value" text="—" />
                                    <Label styleClass="stat-sub" text="pers. / chambre" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-orange" text="🏨" />
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Hébergements" />
                                    <Label fx:id="statHeb" styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-sub" text="avec chambres" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- FORM PANEL -->
                    <VBox fx:id="formPanel" managed="false" spacing="0" styleClass="form-card, inline-form-panel" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="cat-form-header">
                            <Label fx:id="formPanelTitle" styleClass="cat-form-title" text="🛏️ Nouvelle Chambre" HBox.hgrow="ALWAYS" />
                            <Button onAction="#onCloseForm" styleClass="fp-close-btn" text="✕" />
                        </HBox>
                        <VBox spacing="16" styleClass="form-body">
                            <padding><Insets bottom="12" left="24" right="24" top="20" /></padding>
                            <HBox spacing="16">
                                <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Numéro de chambre *" />
                                    <TextField fx:id="numeroField" onKeyReleased="#validateNumero" promptText="Ex: 101" styleClass="form-input" />
                                    <Label fx:id="errNumero" managed="false" styleClass="err-msg" visible="false" />
                                </VBox>
                                <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Hébergement *" />
                                    <ComboBox fx:id="hebCombo" maxWidth="Infinity" promptText="-- Sélectionner --" styleClass="sort-select" />
                                    <Label fx:id="errHeb" managed="false" styleClass="err-msg" visible="false" />
                                </VBox>
                            </HBox>
                            <HBox spacing="16">
                                <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Type *" />
                                    <ComboBox fx:id="typeCombo" maxWidth="Infinity" styleClass="sort-select" />
                                </VBox>
                                <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Prix / nuit (DT) *" />
                                    <TextField fx:id="prixField" onKeyReleased="#validatePrix" promptText="Ex: 120" styleClass="form-input" />
                                    <Label fx:id="errPrix" managed="false" styleClass="err-msg" visible="false" />
                                </VBox>
                                <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Capacité (1-4) *" />
                                    <TextField fx:id="capField" onKeyReleased="#validateCap" promptText="Ex: 2" styleClass="form-input" />
                                    <Label fx:id="errCap" managed="false" styleClass="err-msg" visible="false" />
                                </VBox>
                            </HBox>
                            <HBox spacing="16">
                                <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Disponibilité" />
                                    <ComboBox fx:id="dispoCombo" maxWidth="Infinity" styleClass="sort-select" />
                                </VBox>
                                <VBox spacing="5" styleClass="form-group" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Description" />
                                    <TextArea fx:id="descField" prefRowCount="3" promptText="Description de la chambre…" styleClass="form-input" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                            <Button onAction="#onCloseForm" styleClass="btn-cancel" text="Annuler" />
                            <Button onAction="#onSave" styleClass="btn-submit" text="💾 Enregistrer" />
                        </HBox>
                    </VBox>

                    <!-- Action Bar -->
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="action-bar">
                        <Button onAction="#onOpenForm" styleClass="btn-primary" text="＋ Ajouter une chambre" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="6" styleClass="search-wrap">
                            <Label styleClass="search-icon" text="🔍" />
                            <TextField fx:id="searchField" onKeyReleased="#onSearch" prefWidth="220" promptText="Rechercher…" styleClass="search-input" />
                        </HBox>
                        <ComboBox fx:id="filterType" onAction="#onSearch" prefWidth="150" promptText="Tous les types" styleClass="sort-select" />
                        <ComboBox fx:id="sortCombo" onAction="#onSearch" prefWidth="160" promptText="Trier par…" styleClass="sort-select" />
                    </HBox>

                    <!-- Table Card -->
                    <VBox spacing="0" styleClass="table-card">
                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="table-card-header">
                            <Label styleClass="table-card-title" text="🛏️ Liste des Chambres" HBox.hgrow="ALWAYS" />
                            <Label fx:id="badgeCount" styleClass="badge, badge-green" text="0" />
                        </HBox>
                        <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNumero" prefWidth="120" text="Numéro" />
                                <TableColumn fx:id="colHeb" prefWidth="170" text="Hébergement" />
                                <TableColumn fx:id="colType" prefWidth="110" text="Type" />
                                <TableColumn fx:id="colPrix" prefWidth="110" text="Prix / nuit" />
                                <TableColumn fx:id="colCap" prefWidth="90" text="Capacité" />
                                <TableColumn fx:id="colDispo" prefWidth="130" text="Disponible" />
                                <TableColumn fx:id="colDesc" prefWidth="170" text="Description" />
                                <TableColumn fx:id="colActions" prefWidth="179.19998779296884" text="Actions" />
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                    <Label styleClass="empty-icon" text="🔍" />
                                    <Label styleClass="empty-label" text="Aucune chambre trouvée." />
                                </VBox>
                            </placeholder>
                        </TableView>

                        <!-- Pagination — même design que ListHebergements -->
                        <HBox fx:id="paginationBar" alignment="CENTER_LEFT" spacing="8" styleClass="pagination-bar">
                            <Label fx:id="pagInfo" styleClass="pag-info" HBox.hgrow="ALWAYS" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox fx:id="pagButtons" spacing="4" />
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
