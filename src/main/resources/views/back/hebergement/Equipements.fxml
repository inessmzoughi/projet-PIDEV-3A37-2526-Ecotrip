<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controller.back.hebergement.EquipementsController">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <VBox spacing="20" styleClass="page-body">
                    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button onAction="#onNavDashboard" styleClass="breadcrumb-link" text="Dashboard" />
                            <Label styleClass="breadcrumb-sep" text=" › " />
                            <Button onAction="#onNavHebergements" styleClass="breadcrumb-link" text="Hébergements" />
                            <Label styleClass="breadcrumb-sep" text=" › " />
                            <Label styleClass="breadcrumb-active" text="Équipements" />
                        </HBox>
                        <Label styleClass="page-title" text="Gestion des Équipements" />
                    </VBox>

                    <HBox spacing="20">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-green" text="🛎️" />
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Total Équipements" />
                                    <Label fx:id="statTotal" styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-sub" text="enregistrés" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-blue" text="📝" />
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Avec description" />
                                    <Label fx:id="statAvecDesc" styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-sub" text="équipements décrits" />
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label styleClass="stat-icon, stat-icon-orange" text="🏨" />
                                <VBox spacing="2">
                                    <Label styleClass="stat-label" text="Hébergements liés" />
                                    <Label fx:id="statHebLies" styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-sub" text="utilisent ces équip." />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- FORM PANEL -->
                    <VBox fx:id="formPanel" managed="false" spacing="0" styleClass="form-card, inline-form-panel" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="cat-form-header">
                            <Label fx:id="formPanelTitle" styleClass="cat-form-title" text="🛎️ Nouvel Équipement" HBox.hgrow="ALWAYS" />
                            <Button onAction="#onCloseForm" styleClass="fp-close-btn" text="✕" />
                        </HBox>
                        <VBox spacing="16" styleClass="form-body">
                            <padding><Insets bottom="12" left="24" right="24" top="20" /></padding>
                            <VBox spacing="5" styleClass="form-group">
                                <Label styleClass="form-label" text="Nom *" />
                                <TextField fx:id="nomField" promptText="Ex: Piscine privée" styleClass="form-input" />
                                <Label fx:id="errNom" managed="false" styleClass="err-msg" visible="false" />
                            </VBox>
                            <VBox spacing="5" styleClass="form-group">
                                <Label styleClass="form-label" text="Description" />
                                <TextArea fx:id="descField" prefRowCount="3" promptText="Courte description…" styleClass="form-input" />
                            </VBox>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="form-footer">
                            <Button onAction="#onCloseForm" styleClass="btn-cancel" text="Annuler" />
                            <Button onAction="#onSave" styleClass="btn-submit" text="💾 Enregistrer" />
                        </HBox>
                    </VBox>

                    <!-- Action Bar -->
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="action-bar">
                        <Button onAction="#onOpenForm" styleClass="btn-primary" text="＋ Ajouter un équipement" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="6" styleClass="search-wrap">
                            <Label styleClass="search-icon" text="🔍" />
                            <TextField fx:id="searchField" onKeyReleased="#onSearch" prefWidth="220" promptText="Rechercher…" styleClass="search-input" />
                        </HBox>
                        <ToggleButton fx:id="toggleCards" onAction="#onToggleCards" styleClass="vt-btn" text="⊞ Cartes" />
                        <ToggleButton fx:id="toggleList" onAction="#onToggleList" selected="true" styleClass="vt-btn, vt-btn-active" text="☰ Liste" />
                    </HBox>

                    <!-- CARD GRID VIEW -->
                    <FlowPane fx:id="cardGrid" hgap="16" managed="false" styleClass="eq-card-grid" vgap="16" visible="false" />

                    <!-- TABLE VIEW -->
                    <VBox fx:id="tableCard" spacing="0" styleClass="table-card">
                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="table-card-header">
                            <Label styleClass="table-card-title" text="🛎️ Liste des Équipements" HBox.hgrow="ALWAYS" />
                            <Label fx:id="badgeCount" styleClass="badge, badge-green" text="0" />
                        </HBox>
                        <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNom" prefWidth="280" text="Nom" />
                                <TableColumn fx:id="colDesc" prefWidth="420" text="Description" />
                                <TableColumn fx:id="colActions" prefWidth="222.39995117187505" text="Actions" />
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                    <Label styleClass="empty-icon" text="🔍" />
                                    <Label styleClass="empty-label" text="Aucun équipement trouvé." />
                                </VBox>
                            </placeholder>
                        </TableView>

                        <!-- Pagination — même design que ListHebergements -->
                        <HBox fx:id="paginationBar" alignment="CENTER_LEFT" spacing="8" styleClass="pagination-bar">
                            <Label fx:id="pagInfo" styleClass="pag-info" HBox.hgrow="ALWAYS" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox fx:id="pagButtons" spacing="4" />
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
