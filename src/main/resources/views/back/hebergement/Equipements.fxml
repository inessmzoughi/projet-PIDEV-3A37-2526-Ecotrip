<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controller.back.hebergement.EquipementsController"
            styleClass="root-pane">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="20">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard"    styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label  text=" › "          styleClass="breadcrumb-sep"/>
                            <Button text="Hébergements" styleClass="breadcrumb-link" onAction="#onNavHebergements"/>
                            <Label  text=" › "          styleClass="breadcrumb-sep"/>
                            <Label  text="Équipements"  styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Gestion des Équipements" styleClass="page-title"/>
                    </VBox>

                    <HBox spacing="20">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🛎️" styleClass="stat-icon, stat-icon-green"/>
                                <VBox spacing="2">
                                    <Label text="Total Équipements" styleClass="stat-label"/>
                                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                                    <Label text="enregistrés" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="📝" styleClass="stat-icon, stat-icon-blue"/>
                                <VBox spacing="2">
                                    <Label text="Avec description" styleClass="stat-label"/>
                                    <Label fx:id="statAvecDesc" text="0" styleClass="stat-value"/>
                                    <Label text="équipements décrits" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🏨" styleClass="stat-icon, stat-icon-orange"/>
                                <VBox spacing="2">
                                    <Label text="Hébergements liés" styleClass="stat-label"/>
                                    <Label fx:id="statHebLies" text="0" styleClass="stat-value"/>
                                    <Label text="utilisent ces équip." styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- FORM PANEL -->
                    <VBox fx:id="formPanel" styleClass="form-card, inline-form-panel"
                          visible="false" managed="false" spacing="0">
                        <HBox styleClass="cat-form-header" alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="formPanelTitle" text="🛎️ Nouvel Équipement"
                                   styleClass="cat-form-title" HBox.hgrow="ALWAYS"/>
                            <Button text="✕" styleClass="fp-close-btn" onAction="#onCloseForm"/>
                        </HBox>
                        <VBox styleClass="form-body" spacing="16">
                            <padding><Insets top="20" right="24" bottom="12" left="24"/></padding>
                            <VBox spacing="5" styleClass="form-group">
                                <Label text="Nom *" styleClass="form-label"/>
                                <TextField fx:id="nomField" promptText="Ex: Piscine privée"
                                           styleClass="form-input"/>
                                <Label fx:id="errNom" styleClass="err-msg" visible="false" managed="false"/>
                            </VBox>
                            <VBox spacing="5" styleClass="form-group">
                                <Label text="Description" styleClass="form-label"/>
                                <TextArea fx:id="descField" promptText="Courte description…"
                                          styleClass="form-input" prefRowCount="3"/>
                            </VBox>
                        </VBox>
                        <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
                            <Button text="Annuler"        styleClass="btn-cancel" onAction="#onCloseForm"/>
                            <Button text="💾 Enregistrer" styleClass="btn-submit" onAction="#onSave"/>
                        </HBox>
                    </VBox>

                    <!-- Action Bar -->
                    <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                        <Button text="＋ Ajouter un équipement" styleClass="btn-primary" onAction="#onOpenForm"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                            <Label text="🔍" styleClass="search-icon"/>
                            <TextField fx:id="searchField" promptText="Rechercher…"
                                       styleClass="search-input" prefWidth="220" onKeyReleased="#onSearch"/>
                        </HBox>
                        <ToggleButton fx:id="toggleCards" text="⊞ Cartes"
                                      styleClass="vt-btn" onAction="#onToggleCards"/>
                        <ToggleButton fx:id="toggleList"  text="☰ Liste"
                                      styleClass="vt-btn, vt-btn-active" selected="true"
                                      onAction="#onToggleList"/>
                    </HBox>

                    <!-- CARD GRID VIEW -->
                    <FlowPane fx:id="cardGrid" hgap="16" vgap="16"
                              styleClass="eq-card-grid" visible="false" managed="false"/>

                    <!-- TABLE VIEW -->
                    <VBox fx:id="tableCard" styleClass="table-card" spacing="0">
                        <HBox styleClass="table-card-header" alignment="CENTER_LEFT" spacing="8">
                            <Label text="🛎️ Liste des Équipements" styleClass="table-card-title" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="badgeCount" text="0" styleClass="badge, badge-green"/>
                        </HBox>
                        <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNom"     text="Nom"         prefWidth="280"/>
                                <TableColumn fx:id="colDesc"    text="Description" prefWidth="420"/>
                                <TableColumn fx:id="colActions" text="Actions"     prefWidth="220"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                    <Label text="🔍" styleClass="empty-icon"/>
                                    <Label text="Aucun équipement trouvé." styleClass="empty-label"/>
                                </VBox>
                            </placeholder>
                        </TableView>

                        <!-- Pagination — même design que ListHebergements -->
                        <HBox fx:id="paginationBar" styleClass="pagination-bar"
                              alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="pagInfo" styleClass="pag-info" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox fx:id="pagButtons" spacing="4"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
