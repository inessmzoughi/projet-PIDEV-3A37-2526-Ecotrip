<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controller.back.ListReservationsController"
            styleClass="root-pane">

    <center>
        <VBox styleClass="main-content">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="24">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <!-- Breadcrumb -->
                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Button text="Dashboard" styleClass="breadcrumb-link" onAction="#onNavDashboard"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Label text="Réservations" styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Gestion des Réservations" styleClass="page-title"/>
                    </VBox>

                    <!-- Stats -->
                    <HBox spacing="16">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                            <Label text="📋 Total" styleClass="stat-label"/>
                            <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                            <Label text="⏳ En attente" styleClass="stat-label"/>
                            <Label fx:id="statPending" text="0" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                            <Label text="✅ Confirmées" styleClass="stat-label"/>
                            <Label fx:id="statConfirmed" text="0" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                            <Label text="❌ Annulées" styleClass="stat-label"/>
                            <Label fx:id="statCancelled" text="0" styleClass="stat-value"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                            <Label text="💰 Revenus" styleClass="stat-label"/>
                            <Label fx:id="statRevenue" text="0.00 TND" styleClass="stat-value"
                                   style="-fx-font-size:16px;"/>
                        </VBox>
                    </HBox>

                    <!-- Filters -->
                    <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                        <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                            <Label text="🔍" styleClass="search-icon"/>
                            <TextField fx:id="searchField" promptText="ID, utilisateur..."
                                       styleClass="search-input" onKeyReleased="#onSearch" prefWidth="160"/>
                        </HBox>
                        <ComboBox fx:id="filterStatus" styleClass="sort-select" prefWidth="130" onAction="#onFilter"/>
                        <ComboBox fx:id="filterType"   styleClass="sort-select" prefWidth="140" onAction="#onFilter"/>
                        <DatePicker fx:id="filterDateFrom" promptText="Début" prefWidth="140"/>
                        <DatePicker fx:id="filterDateTo"   promptText="Fin"   prefWidth="140"/>
                        <Button text="↺ Réinitialiser" styleClass="btn-cancel" onAction="#onReset"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📋 Réservations" styleClass="table-card-title"/>
                            <Label fx:id="badgeCount" text="0" styleClass="badge badge-green"/>
                        </HBox>
                    </HBox>

                    <!-- Table -->
                    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
                        <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId"       text="#"          prefWidth="60"/>
                                <TableColumn fx:id="colUser"     text="Utilisateur" prefWidth="100"/>
                                <TableColumn fx:id="colType"     text="Type"        prefWidth="120"/>
                                <TableColumn fx:id="colLabel"    text="Élément"     prefWidth="160"/>
                                <TableColumn fx:id="colDateFrom" text="Arrivée"     prefWidth="100"/>
                                <TableColumn fx:id="colDateTo"   text="Départ"      prefWidth="100"/>
                                <TableColumn fx:id="colPersons"  text="Pers."       prefWidth="60"/>
                                <TableColumn fx:id="colTotal"    text="Total"       prefWidth="110"/>
                                <TableColumn fx:id="colStatus"   text="Statut"      prefWidth="120"/>
                                <TableColumn fx:id="colActions"  text="Actions"     prefWidth="120"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                    <Label text="📭" styleClass="empty-icon"/>
                                    <Label text="Aucune réservation trouvée." styleClass="empty-label"/>
                                </VBox>
                            </placeholder>
                        </TableView>
                        <HBox styleClass="pagination-bar" alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="pagInfo" styleClass="pag-info" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox fx:id="pagButtons" spacing="4"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>