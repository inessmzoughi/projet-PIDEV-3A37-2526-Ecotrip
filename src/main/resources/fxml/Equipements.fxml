<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.EquipementsController"
            styleClass="root-pane"
            stylesheets="@../css/ecotrip.css">

    <!-- ═══ SIDEBAR ═══ -->
    <left>
        <VBox styleClass="sidebar" minWidth="240" maxWidth="240">
            <HBox styleClass="sidebar-logo" alignment="CENTER_LEFT" spacing="12">
                <Label text="🌿" styleClass="sidebar-logo-icon"/>
                <VBox spacing="2">
                    <Label text="EcoTrip" styleClass="brand-name"/>
                    <Label text="Admin Panel" styleClass="brand-sub"/>
                </VBox>
            </HBox>
            <VBox styleClass="nav-section" VBox.vgrow="ALWAYS">
                <Label text="PRINCIPAL" styleClass="nav-label"/>
                <Button text="  📊  Dashboard"     styleClass="nav-item" maxWidth="Infinity"/>
                <Label text="CONTENU" styleClass="nav-label"/>
                <Button text="  🏨  Hébergements"  styleClass="nav-item" maxWidth="Infinity" onAction="#onNavHebergements"/>
                <Button text="      📋  Liste"       styleClass="nav-item nav-sub-item" maxWidth="Infinity" onAction="#onNavHebergements"/>
                <Button text="      🛏  Chambres"    styleClass="nav-item nav-sub-item" maxWidth="Infinity" onAction="#onNavChambres"/>
                <Button text="      🔧  Équipements" styleClass="nav-item nav-sub-item nav-item-active" maxWidth="Infinity"/>
                <Button text="      🏷  Catégories"  styleClass="nav-item nav-sub-item" maxWidth="Infinity" onAction="#onNavCategories"/>
                <Label text="GESTION" styleClass="nav-label"/>
                <Button text="  📋  Réservations"  styleClass="nav-item" maxWidth="Infinity"/>
                <Button text="  👥  Utilisateurs"  styleClass="nav-item" maxWidth="Infinity"/>
            </VBox>
            <VBox styleClass="sidebar-footer">
                <Separator styleClass="sidebar-sep"/>
                <HBox styleClass="sidebar-user" alignment="CENTER_LEFT" spacing="10">
                    <Label text="IN" styleClass="avatar"/>
                    <VBox>
                        <Label text="Ines Mzoughi" styleClass="user-name"/>
                        <Label text="Administrateur" styleClass="user-role"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ═══ CENTER ═══ -->
    <center>
        <VBox styleClass="main-content">

            <!-- Topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <Label text="🛎️ Équipements" styleClass="topbar-title" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="admin@ecotrip.tn" styleClass="topbar-email"/>
                <Button text="Déconnexion" styleClass="btn-logout" onAction="#onLogout"/>
            </HBox>

            <!-- Page Body -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox styleClass="page-body" spacing="20">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <!-- Breadcrumb + Title -->
                    <VBox spacing="4">
                        <HBox spacing="4">
                            <Label text="Dashboard" styleClass="breadcrumb-link"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Label text="Hébergements" styleClass="breadcrumb-link"/>
                            <Label text=" › " styleClass="breadcrumb-sep"/>
                            <Label text="Équipements" styleClass="breadcrumb-active"/>
                        </HBox>
                        <Label text="Gestion des Équipements" styleClass="page-title"/>
                    </VBox>

                    <!-- Stat Cards -->
                    <HBox spacing="20">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🛎️" styleClass="stat-icon stat-icon-green"/>
                                <VBox spacing="2">
                                    <Label text="Total Équipements" styleClass="stat-label"/>
                                    <Label fx:id="statTotal" text="0" styleClass="stat-value"/>
                                    <Label text="disponibles" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="📂" styleClass="stat-icon stat-icon-blue"/>
                                <VBox spacing="2">
                                    <Label text="Catégories" styleClass="stat-label"/>
                                    <Label fx:id="statCats" text="—" styleClass="stat-value"/>
                                    <Label text="de types" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="⭐" styleClass="stat-icon stat-icon-orange"/>
                                <VBox spacing="2">
                                    <Label text="Premium" styleClass="stat-label"/>
                                    <Label fx:id="statPremium" text="—" styleClass="stat-value"/>
                                    <Label text="équipements" styleClass="stat-sub"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Category Filter Tabs -->
                    <HBox fx:id="catTabsPane" spacing="8" alignment="CENTER_LEFT"/>

                    <!-- FORM PANEL -->
                    <VBox fx:id="formPanel" styleClass="form-card inline-form-panel"
                          visible="false" managed="false" spacing="0">

                        <HBox styleClass="cat-form-header" alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="formPanelTitle" text="🛎️ Nouvel Équipement"
                                   styleClass="cat-form-title" HBox.hgrow="ALWAYS"/>
                            <Button text="✕" styleClass="fp-close-btn" onAction="#onCloseForm"/>
                        </HBox>

                        <VBox styleClass="form-body" spacing="16">
                            <padding><Insets top="20" right="24" bottom="12" left="24"/></padding>

                            <!-- Row 1: Nom -->
                            <VBox spacing="5" styleClass="form-group">
                                <Label text="Nom *" styleClass="form-label"/>
                                <TextField fx:id="nomField" promptText="Ex: Piscine privée"
                                           styleClass="form-input"/>
                            </VBox>

                            <!-- Row 2: Description -->
                            <VBox spacing="5" styleClass="form-group">
                                <Label text="Description" styleClass="form-label"/>
                                <TextArea fx:id="descField" promptText="Courte description…"
                                          styleClass="form-input" prefRowCount="3"/>
                            </VBox>
                        </VBox>

                        <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
                            <Button text="Annuler"         styleClass="btn-cancel" onAction="#onCloseForm"/>
                            <Button text="💾 Enregistrer" styleClass="btn-submit" onAction="#onSave"/>
                        </HBox>
                    </VBox>

                    <!-- Action Bar -->
                    <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="12">
                        <Button text="＋ Ajouter un équipement" styleClass="btn-primary" onAction="#onOpenForm"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox styleClass="search-wrap" alignment="CENTER_LEFT" spacing="6">
                            <Label text="🔍" styleClass="search-icon"/>
                            <TextField fx:id="searchField" promptText="Rechercher…"
                                       styleClass="search-input" prefWidth="220"
                                       onKeyReleased="#onSearch"/>
                        </HBox>
                        <ToggleButton fx:id="toggleCards" text="⊞ Cartes"
                                      styleClass="vt-btn" onAction="#onToggleView"/>
                        <ToggleButton fx:id="toggleList"  text="☰ Liste"
                                      styleClass="vt-btn vt-btn-active" selected="true"
                                      onAction="#onToggleView"/>
                    </HBox>

                    <!-- CARD GRID VIEW -->
                    <FlowPane fx:id="cardGrid" hgap="16" vgap="16"
                              styleClass="eq-card-grid"
                              visible="false" managed="false"/>

                    <!-- TABLE VIEW -->
                    <VBox fx:id="tableCard" styleClass="table-card" spacing="0">
                        <HBox styleClass="table-card-header" alignment="CENTER_LEFT" spacing="8">
                            <Label text="🛎️ Liste des Équipements" styleClass="table-card-title" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="badgeCount" text="0" styleClass="badge badge-green"/>
                        </HBox>

                        <TableView fx:id="tableView" styleClass="main-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colIndex"   text="#"           prefWidth="50"/>
                                <TableColumn fx:id="colNom"     text="Nom"         prefWidth="250"/>
                                <TableColumn fx:id="colDesc"    text="Description" prefWidth="350"/>
                                <TableColumn fx:id="colActions" text="Actions"     prefWidth="160"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8" styleClass="empty-state">
                                    <Label text="🔍" styleClass="empty-icon"/>
                                    <Label text="Aucun équipement trouvé." styleClass="empty-label"/>
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>